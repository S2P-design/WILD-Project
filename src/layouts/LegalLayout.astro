---
interface Props {
  title: string;
  description: string;
  pageTitle: string;
  intro: string;
}

const { title, description, pageTitle, intro } = Astro.props;
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/favicon-180.png">
</head>
<body>

<nav>
  <a href="/" class="nav-brand"><img src="/wp-logo.png" alt="Wild Project" class="nav-logo"></a>
  <a href="/" class="nav-back">&larr; Zur&uuml;ck</a>
</nav>

<div class="page">
  <h1 class="page-title">{pageTitle}<span>.</span></h1>
  {intro && <p class="page-intro">{intro}</p>}

  <slot />

  <div class="footer">
    <p>&copy; 2026 Wild Project — Ren&eacute; Wild</p>
    <p style="margin-top: 8px;"><a href="/">Startseite</a> &middot; <a href="/impressum">Impressum</a> &middot; <a href="/datenschutz">Datenschutz</a> &middot; <a href="/kontakt">Kontakt</a></p>
  </div>
</div>

</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<style>
  nav {
    display: flex; align-items: center; justify-content: space-between;
    padding: 24px 3rem;
    position: sticky; top: 0;
    background: rgba(5,5,5,0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    z-index: 10;
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }
  .nav-brand { display: flex; align-items: center; }
  .nav-logo { height: 36px; width: auto; }
  .nav-back {
    font-size: 11px; font-weight: 400;
    letter-spacing: 2px; text-transform: uppercase;
    color: var(--grey-mid);
    transition: color 0.2s;
  }
  .nav-back:hover { color: var(--orange); opacity: 1; }

  .page { max-width: 680px; margin: 0 auto; padding: 60px 2rem 40px; }

  .page-title {
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    font-weight: 700;
    color: var(--white);
    letter-spacing: -1px;
    margin-bottom: 8px;
  }
  .page-title span { color: var(--orange); }
  .page-intro {
    font-size: 14px;
    color: var(--grey-mid);
    margin-bottom: 18px;
    font-style: italic;
  }
  .lang-note {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 10px;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--grey-dark);
    padding: 6px 12px;
    border: 1px solid rgba(255,255,255,0.06);
    background: rgba(255,255,255,0.02);
    margin-bottom: 40px;
  }
  .lang-note-dot {
    width: 5px; height: 5px; border-radius: 50%;
    background: var(--orange);
    flex-shrink: 0;
  }

  :global(h2) {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--orange);
    margin-top: 36px;
    margin-bottom: 12px;
  }
  :global(h2::before) {
    content: '';
    display: inline-block;
    width: 16px; height: 1.5px;
    background: var(--orange);
    margin-right: 10px;
    vertical-align: middle;
  }

  :global(h3) {
    font-size: 14px;
    font-weight: 500;
    color: var(--silver);
    margin-top: 20px;
    margin-bottom: 8px;
  }

  :global(p), :global(ul) { font-size: 14px; color: var(--grey-mid); margin-bottom: 12px; }
  :global(ul) { padding-left: 20px; }
  :global(li) { margin-bottom: 6px; }
  :global(strong) { color: var(--silver); font-weight: 500; }

  :global(.legal-box) {
    background: rgba(255,255,255,0.03);
    border-left: 2px solid var(--orange);
    padding: 20px 24px;
    margin: 20px 0;
  }
  :global(.legal-box p) { margin-bottom: 4px; }

  /* ── BRANDED CLAUSE CARD ─────────────── */
  :global(.clause-card) {
    position: relative;
    background: linear-gradient(180deg, rgba(252,80,0,0.04), rgba(255,255,255,0.02));
    border: 1px solid rgba(255,255,255,0.08);
    padding: 28px 28px 18px;
    margin: 18px 0 28px;
    overflow: hidden;
  }
  :global(.clause-card::before),
  :global(.clause-card::after) {
    content: '';
    position: absolute;
    left: 0; right: 0;
    height: 1px;
    background: var(--orange);
    opacity: 0.45;
  }
  :global(.clause-card::before) { top: 0; }
  :global(.clause-card::after) { bottom: 0; }

  :global(.clause-marks) {
    position: absolute;
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 1.2px;
    color: rgba(255,255,255,0.5);
    white-space: nowrap;
  }
  :global(.clause-marks-l) { top: 8px; left: 14px; }
  :global(.clause-marks-r) { bottom: 6px; right: 14px; }

  :global(.clause-eyebrow) {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    margin: 4px 0 10px;
  }
  :global(.clause-dot) {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--orange);
    box-shadow: 0 0 0 0 rgba(252,80,0,0.55);
    animation: clausePulse 2.4s ease-in-out infinite;
  }
  @keyframes clausePulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(252,80,0,0.55); transform: scale(1); }
    50%      { box-shadow: 0 0 0 6px rgba(252,80,0,0); transform: scale(1.15); }
  }

  :global(.clause-statement) {
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: clamp(11px, 1.1vw, 13px);
    font-weight: 600;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.92);
    line-height: 1.6;
    margin: 0 0 18px;
    padding-bottom: 16px;
    border-bottom: 1px dashed rgba(255,255,255,0.10);
  }
  :global(.clause-bracket) {
    color: var(--orange);
    margin: 0 1px;
    font-weight: 400;
  }
  :global(.clause-card h3) {
    margin-top: 16px;
  }
  :global(.clause-card p),
  :global(.clause-card ul) {
    color: var(--grey-mid);
  }

  :global(.side-note) {
    font-size: 12px;
    color: var(--grey-dark);
    margin-top: -4px;
    margin-bottom: 16px;
  }

  :global(a) { color: var(--orange); text-decoration: none; transition: opacity 0.2s; }
  :global(a:hover) { opacity: 0.7; }

  .footer {
    text-align: center;
    padding: 40px 2rem 24px;
    border-top: 1px solid rgba(255,255,255,0.06);
    margin-top: 48px;
  }
  .footer p { font-size: 10px; color: var(--grey-dark); letter-spacing: 1px; }
  .footer a { color: var(--grey-mid); }
  .footer a:hover { color: var(--orange); opacity: 1; }

  @media (max-width: 700px) {
    nav { padding: 14px 1.5rem; }
    .page { padding: 40px 1.5rem 24px; }
  }
</style>
