---
interface Props {
  href: string;
  icon: string;
  title: string;
  desc?: string;
  descEn?: string;
}

const { href, icon, title, desc, descEn } = Astro.props;
---

<a href={href} target="_blank" rel="noopener" class="link-item">
  <div class="link-info">
    <div class="link-icon">{icon}</div>
    <div>
      <div class="link-title">{title}</div>
      {desc && (
        descEn ? (
          <div class="link-desc">
            <span class="t-de">{desc}</span>
            <span class="t-en">{descEn}</span>
          </div>
        ) : (
          <div class="link-desc">{desc}</div>
        )
      )}
    </div>
  </div>
  <span class="link-arrow">&rsaquo;</span>
</a>

<style>
  .link-item {
    display: flex; align-items: center; justify-content: space-between;
    padding: 16px 20px;
    margin-bottom: 8px;
    background: rgba(255,255,255,0.03);
    backdrop-filter: blur(3px);
    -webkit-backdrop-filter: blur(3px);
    border: 1px solid rgba(255,255,255,0.05);
    transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    cursor: pointer;
  }
  .link-item:hover {
    background: rgba(255,255,255,0.06);
    backdrop-filter: blur(4px);
    border-color: rgba(252,80,0,0.2);
    transform: translateX(6px);
    box-shadow: 0 4px 16px rgba(252,80,0,0.04);
  }
  .link-info {
    display: flex; align-items: center; gap: 14px;
  }
  .link-icon {
    width: 36px; height: 36px;
    display: flex; align-items: center; justify-content: center;
    background: rgba(252,80,0,0.1);
    color: var(--orange);
    font-size: 12px; font-weight: 700;
    letter-spacing: 0.5px;
    flex-shrink: 0;
    transition: all 0.25s;
  }
  .link-item:hover .link-icon {
    background: var(--orange);
    color: var(--white);
  }
  .link-title {
    font-size: 14px; font-weight: 500;
    color: var(--white);
  }
  .link-desc {
    font-size: 11px; color: var(--grey-mid);
    margin-top: 2px;
  }
  .link-arrow {
    color: var(--grey-dark);
    font-size: 16px;
    transition: all 0.25s;
  }
  .link-item:hover .link-arrow {
    color: var(--orange);
    transform: translateX(3px);
  }

  /* ── Light Mode ── */
  :global(body.light) .link-item {
    background: rgba(0,0,0,0.02);
    border-color: rgba(0,0,0,0.05);
  }
  :global(body.light) .link-item:hover {
    background: rgba(252,80,0,0.03);
    border-color: rgba(252,80,0,0.15);
    transform: translateX(6px);
  }
  :global(body.light) .link-icon {
    background: rgba(252,80,0,0.07);
  }
  :global(body.light) .link-item:hover .link-icon {
    background: var(--orange);
    color: #fff;
  }
  :global(body.light) .link-title { color: #1a1a1a; }
  :global(body.light) .link-desc { color: rgba(0,0,0,0.4); }
  :global(body.light) .link-arrow { color: rgba(0,0,0,0.15); }
  :global(body.light) .link-item:hover .link-arrow { color: var(--orange); }

  @media (max-width: 700px) {
    .link-item { padding: 8px 10px; margin-bottom: 3px; }
    .link-icon { width: 26px; height: 26px; font-size: 9px; }
    .link-title { font-size: 11px; }
    .link-desc { display: none; }
  }
</style>
