---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-left">
      <p class="copyright">&copy; 2026 Wild Project — René Wild</p>
      <p class="footer-links">
        <a href="/impressum">Impressum</a>
        <span class="sep">&middot;</span>
        <a href="/datenschutz">Datenschutz</a>
        <span class="sep">&middot;</span>
        <a href="/kontakt">Kontakt</a>
      </p>
    </div>
    <div class="footer-right">
      <img src="/wp-logo.png" alt="WP" class="footer-logo">
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 28px 3rem 32px;
    background: linear-gradient(180deg, transparent 0%, rgba(0,0,0,0.85) 100%);
    padding-top: 40px;
    position: relative;
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    font-variant-numeric: tabular-nums;
  }
  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }
  .footer-left {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .copyright {
    font-size: 9px;
    color: rgba(255,255,255,0.4);
    letter-spacing: 1px;
  }
  .footer-links {
    font-size: 9px;
    letter-spacing: 1px;
  }
  .footer-links a {
    color: rgba(255,255,255,0.4);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-links a:hover { color: var(--orange); }
  .footer-links .sep {
    color: rgba(255,255,255,0.2);
    margin: 0 5px;
  }
  .footer-right {
    display: flex;
    align-items: center;
  }
  .footer-logo {
    width: 24px;
    height: 24px;
    opacity: 0.6;
    transition: opacity 0.3s;
  }
  .footer-logo:hover { opacity: 0.9; }

  @media (max-width: 700px) {
    .footer { padding: 22px 1.25rem 32px; }
    .footer-inner {
      flex-direction: column-reverse;
      align-items: center;
      text-align: center;
      gap: 18px;
    }
    .footer-left { align-items: center; gap: 8px; }
    .copyright { font-size: 9px; }
    .footer-links { font-size: 9px; }
    .footer-links .sep { margin: 0 4px; }
    .footer-logo { width: 26px; height: 26px; }
  }
</style>
