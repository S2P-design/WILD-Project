---
interface Props {
  tagline?: string;
  taglineSteps?: number;
  taglineWidthEm?: number;
}
const {
  tagline = 'LIVE BY DESIGN, NOT BY DEFAULT.',
  taglineSteps = 32,
  taglineWidthEm = 25.5,
} = Astro.props;
---

<footer class="footer" style={`--tg-steps:${taglineSteps};--tg-width:${taglineWidthEm}em;`}>
  <div class="footer-inner">
    <div class="footer-left">
      <p class="copyright">&copy; 2026 Wild Project — René Wild</p>
      <p class="footer-links">
        <a href="/impressum"><span class="t-de">Impressum</span><span class="t-en">Legal</span></a>
        <span class="sep">&middot;</span>
        <a href="/datenschutz"><span class="t-de">Datenschutz</span><span class="t-en">Privacy</span></a>
        <span class="sep">&middot;</span>
        <a href="/basecamp">Basecamp</a>
        <span class="sep">&middot;</span>
        <a href="/shop">Shop</a>
        <span class="sep">&middot;</span>
        <a href="/card"><span class="t-de">vCard</span><span class="t-en">vCard</span></a>
      </p>
    </div>
    <div class="footer-right">
      <img src="/wp-logo.png" alt="WP" class="footer-logo">
      <p class="footer-tagline">{tagline}</p>
      <p class="footer-coords"><span class="coord-dot" aria-hidden="true"></span>47.8561° N &nbsp; 12.1289° E</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 28px 3rem 32px;
    background: linear-gradient(180deg, transparent 0%, rgba(0,0,0,0.85) 100%);
    padding-top: 40px;
    position: relative;
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    font-variant-numeric: tabular-nums;
  }
  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  /* ── Links: Copyright + Links ── */
  .footer-left {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .copyright {
    font-size: 9px;
    color: rgba(255,255,255,0.4);
    letter-spacing: 1px;
  }
  .footer-links {
    font-size: 9px;
    letter-spacing: 1px;
  }
  .footer-links a {
    color: rgba(255,255,255,0.4);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-links a:hover { color: var(--orange); }
  .footer-links .sep {
    color: rgba(255,255,255,0.2);
    margin: 0 5px;
  }

  /* ── Rechts: Logo + Claim + Coords ── */
  .footer-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 6px;
  }
  .footer-logo {
    width: 24px;
    height: 24px;
    opacity: 0.6;
    transition: opacity 0.3s;
    margin-bottom: 2px;
  }
  .footer-logo:hover { opacity: 0.9; }
  .footer-tagline {
    font-size: 9px;
    font-weight: 400;
    letter-spacing: 2px;
    color: rgba(255,255,255,0.4);
    overflow: hidden;
    border-right: 2px solid var(--orange);
    white-space: nowrap;
    width: 0;
    animation: typing 2.5s steps(var(--tg-steps, 32)) 0.5s forwards, blink 0.6s step-end infinite 0.5s;
  }
  @keyframes typing {
    to { width: var(--tg-width, 25.5em); }
  }
  @keyframes blink {
    50% { border-color: transparent; }
  }
  .footer-coords {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 9px;
    font-weight: 300;
    letter-spacing: 1.5px;
    color: rgba(255,255,255,0.42);
    font-variant-numeric: tabular-nums;
  }
  .coord-dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: var(--orange);
    box-shadow: 0 0 0 0 rgba(252,80,0,0.55);
    animation: coordPulse 2.4s ease-in-out infinite;
    flex-shrink: 0;
  }
  @keyframes coordPulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(252,80,0,0.55); transform: scale(1); }
    50%      { box-shadow: 0 0 0 5px rgba(252,80,0,0); transform: scale(1.2); }
  }

  /* ── Light Mode ── */
  :global(body.light) .footer {
    background: linear-gradient(180deg,
      rgba(40,40,40,0) 0%,
      rgba(30,30,30,0.6) 30%,
      rgba(18,18,18,0.95) 75%,
      rgba(10,10,10,1) 100%);
  }
  :global(body.light) .copyright,
  :global(body.light) .footer-links a,
  :global(body.light) .footer-tagline,
  :global(body.light) .footer-coords {
    color: rgba(255,255,255,0.55) !important;
  }
  :global(body.light) .footer-links .sep { color: rgba(255,255,255,0.2) !important; }
  :global(body.light) .copyright { color: rgba(0,0,0,0.55); }
  :global(body.light) .footer-links a { color: rgba(0,0,0,0.55); }
  :global(body.light) .footer-links a:hover { color: var(--orange); }
  :global(body.light) .footer-links .sep { color: rgba(0,0,0,0.25); }
  :global(body.light) .footer-tagline { color: rgba(0,0,0,0.5); border-right-color: var(--orange); }
  :global(body.light) .footer-coords { color: rgba(0,0,0,0.55); }

  /* ── Mobile ── */
  @media (max-width: 700px) {
    .footer { padding: 22px 1.25rem 32px; }
    .footer-inner {
      flex-direction: column-reverse;
      align-items: center;
      text-align: center;
      gap: 22px;
    }
    .footer-left { align-items: center; gap: 8px; }
    .footer-right { align-items: center; gap: 8px; }
    .copyright { font-size: 9px; }
    .footer-links { font-size: 9px; }
    .footer-links .sep { margin: 0 4px; }
    .footer-tagline {
      font-size: 8px;
      letter-spacing: 1.5px;
      animation: typing 2.5s steps(32) 0.5s forwards, blink 0.6s step-end infinite 0.5s;
    }
    .footer-coords { font-size: 9px; }
    .footer-logo { width: 26px; height: 26px; }
  }
</style>
