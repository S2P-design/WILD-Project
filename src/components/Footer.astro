---
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-left">
      <p class="copyright">&copy; 2026 Wild Project — René Wild</p>
      <p class="footer-links">
        <a href="/impressum"><span class="t-de">Impressum</span><span class="t-en">Legal</span></a>
        <span class="sep">&middot;</span>
        <a href="/datenschutz"><span class="t-de">Datenschutz</span><span class="t-en">Privacy</span></a>
        <span class="sep">&middot;</span>
        <a href="/kontakt"><span class="t-de">Kontakt</span><span class="t-en">Contact</span></a>
      </p>
    </div>
    <div class="footer-right">
      <span class="lang-toggle" aria-label="Sprache wählen">
        <button type="button" class="lang-btn" data-set-lang="de">DE</button>
        <span class="lang-sep">/</span>
        <button type="button" class="lang-btn" data-set-lang="en">EN</button>
      </span>
      <img src="/wp-logo.png" alt="WP" class="footer-logo">
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 28px 3rem 32px;
    background: linear-gradient(180deg, transparent 0%, rgba(0,0,0,0.85) 100%);
    padding-top: 40px;
    position: relative;
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    font-variant-numeric: tabular-nums;
  }
  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  /* ── Links: Copyright + Links ── */
  .footer-left {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .copyright {
    font-size: 9px;
    color: rgba(255,255,255,0.4);
    letter-spacing: 1px;
  }
  .footer-links {
    font-size: 9px;
    letter-spacing: 1px;
  }
  .footer-links a {
    color: rgba(255,255,255,0.4);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-links a:hover { color: var(--orange); }
  .footer-links .sep {
    color: rgba(255,255,255,0.2);
    margin: 0 5px;
  }

  /* ── Rechts: Toggle + Logo ── */
  .footer-right {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .lang-toggle {
    display: inline-flex;
    align-items: center;
    font-size: 9px;
    letter-spacing: 1.5px;
    color: rgba(255,255,255,0.4);
  }
  .lang-btn {
    background: transparent;
    border: none;
    padding: 4px 2px;
    font: inherit;
    color: inherit;
    cursor: pointer;
    letter-spacing: inherit;
    transition: color 0.2s;
  }
  .lang-btn:hover { color: var(--orange); }
  :global(html[data-lang="de"]) .lang-btn[data-set-lang="de"],
  :global(html[data-lang="en"]) .lang-btn[data-set-lang="en"] {
    color: var(--orange);
  }
  .lang-sep {
    color: rgba(255,255,255,0.2);
    margin: 0 3px;
  }
  .footer-logo {
    width: 24px;
    height: 24px;
    opacity: 0.6;
    transition: opacity 0.3s;
  }
  .footer-logo:hover { opacity: 0.9; }

  /* ── Mobile ── */
  @media (max-width: 700px) {
    .footer { padding: 22px 1.25rem 32px; }
    .footer-inner {
      flex-direction: column-reverse;
      align-items: center;
      text-align: center;
      gap: 18px;
    }
    .footer-left { align-items: center; gap: 8px; }
    .footer-right { gap: 14px; }
    .copyright { font-size: 9px; }
    .footer-links { font-size: 9px; }
    .footer-links .sep { margin: 0 4px; }
    .footer-logo { width: 26px; height: 26px; }
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.lang-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const lang = btn.dataset.setLang;
      if (lang !== 'de' && lang !== 'en') return;
      document.documentElement.setAttribute('data-lang', lang);
      document.documentElement.lang = lang;
      try { localStorage.setItem('wp_lang', lang); } catch (_) {}
    });
  });
</script>
