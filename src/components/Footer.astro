---
---

<footer class="footer">
  <div class="footer-coords" aria-label="Standorte">
    <span class="footer-coord footer-coord-left">
      <span class="fc-city">Rosenheim</span>
      <span class="fc-sep">·</span>
      <span class="fc-val">47.8561°N · 12.1289°E</span>
    </span>
    <span class="footer-coord footer-coord-right">
      <span class="fc-val">46.6248°N · 14.3057°E</span>
      <span class="fc-sep">·</span>
      <span class="fc-city">Klagenfurt</span>
    </span>
  </div>

  <div class="footer-inner">
    <div class="footer-left">
      <p class="copyright">&copy; 2026 Wild Project</p>
      <p class="footer-links">
        <a href="/impressum">Impressum</a>
        <span class="sep">&middot;</span>
        <a href="/datenschutz">Datenschutz</a>
        <span class="sep">&middot;</span>
        <a href="/kontakt">Kontakt</a>
      </p>
    </div>
    <div class="footer-right">
      <img src="/wp-logo.png" alt="WP" class="footer-logo">
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 28px 3rem 32px;
    background: linear-gradient(180deg, transparent 0%, rgba(0,0,0,0.85) 100%);
    padding-top: 40px;
    position: relative;
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    font-variant-numeric: tabular-nums;
  }

  /* ── Coordinates row (Rosenheim ↔ Klagenfurt) ── */
  .footer-coords {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    margin-bottom: 26px;
    font-size: 9px;
    letter-spacing: 1.4px;
    color: rgba(255,255,255,0.32);
  }
  .footer-coord {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .footer-coord .fc-city {
    color: rgba(255,255,255,0.55);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
  }
  .footer-coord .fc-sep {
    color: var(--orange);
    opacity: 0.55;
  }
  .footer-coord .fc-val {
    color: rgba(255,255,255,0.32);
  }
  .footer-coord-right { text-align: right; }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }
  .footer-left {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .copyright {
    font-size: 9px;
    color: rgba(255,255,255,0.4);
    letter-spacing: 1px;
  }
  .footer-links {
    font-size: 9px;
    letter-spacing: 1px;
  }
  .footer-links a {
    color: rgba(255,255,255,0.4);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-links a:hover { color: var(--orange); }
  .footer-links .sep {
    color: rgba(255,255,255,0.2);
    margin: 0 5px;
  }
  .footer-right {
    display: flex;
    align-items: center;
  }
  .footer-logo {
    width: 24px;
    height: 24px;
    opacity: 0.6;
    transition: opacity 0.3s;
  }
  .footer-logo:hover { opacity: 0.9; }

  @media (max-width: 700px) {
    .footer { padding: 22px 1.25rem 32px; }
    .footer-coords {
      flex-direction: column;
      align-items: center;
      gap: 6px;
      margin-bottom: 20px;
      font-size: 8.5px;
      letter-spacing: 1.2px;
    }
    .footer-coord-right { text-align: center; }
    .footer-inner {
      flex-direction: column-reverse;
      align-items: center;
      text-align: center;
      gap: 18px;
    }
    .footer-left { align-items: center; gap: 8px; }
    .copyright { font-size: 9px; }
    .footer-links { font-size: 9px; }
    .footer-links .sep { margin: 0 4px; }
    .footer-logo { width: 26px; height: 26px; }
  }
</style>
