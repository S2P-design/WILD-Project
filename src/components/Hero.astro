    }
    .hero-meta-line {
      justify-content: center;
      gap: 8px;
    }
    .hero-meta-line .city { min-width: 0; }
  }
  @keyframes heroMetaFadeMobile {
    to { opacity: 1; transform: translateY(0); }
  }
  @media (max-width: 400px) {
    .hero { padding-top: 26vh; }
    .hero h1 { letter-spacing: -1px; font-size: 2.2rem; }
