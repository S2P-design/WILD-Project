---
// Shift2Pro Podcast CTA — sits near the bottom, above the contact line
---

<section class="pod" aria-labelledby="pod-title">
  <div class="pod-label">
    <span class="pod-dot" aria-hidden="true"></span>
    <span class="t-de">Hör rein</span><span class="t-en">Tune in</span>
  </div>

  <h2 class="pod-title" id="pod-title">
    <span class="t-de">Der <em>Shift2Pro</em> Podcast.</span>
    <span class="t-en">The <em>Shift2Pro</em> Podcast.</span>
  </h2>

  <p class="pod-sub">
    <span class="t-de">Inspire · Develop · Connect — Gespräche mit Menschen, die den Sport voranbringen.</span>
    <span class="t-en">Inspire · Develop · Connect — conversations with the people moving the game forward.</span>
  </p>

  <div class="pod-actions">
    <a href="https://www.shift2pro.com" target="_blank" rel="noopener" class="pod-cta">
      <span><span class="t-de">Alle Episoden</span><span class="t-en">All episodes</span></span>
      <span class="pod-arrow">↗</span>
    </a>
    <div class="pod-platforms">
      <span class="pod-soon">
        <span class="pod-soon-dot" aria-hidden="true"></span>
        <span class="t-de">Bald auf</span><span class="t-en">Soon on</span>
      </span>
      <span class="pod-platform">APPLE</span>
      <span class="pod-sep">·</span>
      <span class="pod-platform">SPOTIFY</span>
      <span class="pod-sep">·</span>
      <span class="pod-platform">YOUTUBE</span>
    </div>
  </div>
</section>

<style>
  .pod {
    padding: 56px 0 24px;
    border-top: 1px solid rgba(255,255,255,0.06);
    margin-top: 40px;
  }
  .pod-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    margin-bottom: 16px;
  }
  .pod-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--orange);
    box-shadow: 0 0 0 0 rgba(252,80,0,0.55);
    animation: podPulse 2.4s ease-in-out infinite;
  }
  @keyframes podPulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(252,80,0,0.55); transform: scale(1); }
    50%      { box-shadow: 0 0 0 6px rgba(252,80,0,0); transform: scale(1.15); }
  }
  .pod-title {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 700;
    letter-spacing: -0.5px;
    line-height: 1.1;
    color: #fff;
    margin: 0 0 10px;
  }
  .pod-title em {
    font-style: normal;
    color: var(--orange);
  }
  .pod-sub {
    font-size: 13px;
    color: rgba(255,255,255,0.55);
    line-height: 1.6;
    max-width: 560px;
    margin: 0 0 26px;
  }
  .pod-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 22px;
  }
  .pod-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 24px;
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    text-decoration: none;
    color: #fff;
    background: transparent;
    border: 1px solid rgba(255,255,255,0.2);
    transition: all 0.25s ease;
  }
  .pod-cta:hover {
    color: var(--orange);
    border-color: var(--orange);
    transform: translateY(-2px);
  }
  .pod-arrow { transition: transform 0.25s ease; }
  .pod-cta:hover .pod-arrow { transform: translate(2px,-2px); }

  .pod-platforms {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px;
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 9px;
    letter-spacing: 2px;
  }
  .pod-soon {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    color: rgba(255,255,255,0.55);
    text-transform: uppercase;
    margin-right: 4px;
  }
  .pod-soon-dot {
    width: 5px; height: 5px; border-radius: 50%;
    background: var(--orange);
    box-shadow: 0 0 0 0 rgba(252,80,0,0.55);
    animation: podPulse 2.4s ease-in-out infinite;
  }
  .pod-platform {
    color: rgba(255,255,255,0.35);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .pod-sep { color: rgba(255,255,255,0.18); }

  :global(body.light) .pod {
    border-top-color: rgba(0,0,0,0.08);
  }
  :global(body.light) .pod-label { color: rgba(0,0,0,0.5); }
  :global(body.light) .pod-title { color: #1a1a1a; }
  :global(body.light) .pod-sub { color: rgba(0,0,0,0.6); }
  :global(body.light) .pod-cta { color: rgba(0,0,0,0.8); border-color: rgba(0,0,0,0.18); }
  :global(body.light) .pod-cta:hover { color: var(--orange); border-color: var(--orange); }
  :global(body.light) .pod-platform { color: rgba(0,0,0,0.5); }
  :global(body.light) .pod-sep { color: rgba(0,0,0,0.25); }

  @media (max-width: 700px) {
    .pod { padding: 40px 0 16px; margin-top: 28px; }
    .pod-label { font-size: 9px; letter-spacing: 1.8px; margin-bottom: 12px; }
    .pod-title { font-size: clamp(1.5rem, 7vw, 2rem); margin-bottom: 8px; }
    .pod-sub { font-size: 12px; line-height: 1.55; margin-bottom: 20px; }
    .pod-actions {
      gap: 14px;
      flex-direction: column;
      align-items: flex-start;
    }
    .pod-cta {
      padding: 13px 18px;
      font-size: 10px;
      letter-spacing: 1.6px;
      width: 100%;
      justify-content: center;
    }
    .pod-platforms {
      font-size: 8px;
      letter-spacing: 1.6px;
      gap: 8px;
      width: 100%;
    }
    .pod-soon { gap: 6px; margin-right: 2px; }
  }
</style>
