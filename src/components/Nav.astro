
<div class="nav-loader"></div>
<nav>
  <a href="/" class="nav-brand"><img src="/wp-logo.png" alt="Wild Project" class="nav-logo"></a>

  <div class="nav-meta">
    <span class="nav-item nav-weather" id="navWeather">···</span>
    <span class="nav-sep">·</span>
    <span class="nav-item" id="navDate">···</span>
    <span class="nav-sep">·</span>
    <span class="nav-item nav-time" id="navTime">···</span>
    <span class="nav-sep nav-sep-strong">·</span>
    <button class="nav-toggle" id="langToggle" title="Sprache / Language" aria-label="Toggle language">DE</button>
    <button class="nav-toggle" id="themeToggle" title="Toggle Light/Dark" aria-label="Toggle theme" style="display:none"><span id="themeLabel">DARK</span></button>
    <span class="nav-sep nav-sep-strong">·</span>
    <a href="/shop" class="nav-cart" title="Shop" aria-label="Shop öffnen">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M3 4h2.2l2.2 11.2a2 2 0 0 0 2 1.6h7.8a2 2 0 0 0 2-1.55L21 8H6.2"
              fill="none" stroke="currentColor" stroke-width="1.6"
              stroke-linecap="round" stroke-linejoin="round"/>
        <circle cx="10" cy="20" r="1.3" fill="currentColor"/>
        <circle cx="17" cy="20" r="1.3" fill="currentColor"/>
      </svg>
      <span class="cart-dot" aria-hidden="true"></span>
    </a>
  </div>
</nav>

<style>
  .nav-loader {
    position: fixed; top: 0; left: 0; right: 0;
    height: 2px;
    z-index: 100;
    overflow: hidden;
  }
  .nav-loader::after {
    content: '';
    position: absolute; top: 0; left: 0;
    width: 100%; height: 100%;
    background: linear-gradient(90deg, transparent, var(--orange) 30%, var(--orange) 70%, transparent);
    animation: loaderSlide 3.5s ease forwards;
  }
  @keyframes loaderSlide {
    0% { transform: translateX(-100%); opacity: 0.8; }
    60% { transform: translateX(0%); opacity: 0.8; }
    100% { transform: translateX(100%); opacity: 0; }
  }

  nav {
    display: flex; align-items: center; justify-content: space-between;
    padding: 24px 3rem;
  }
  .nav-brand { display: flex; align-items: center; }
  .nav-logo {
    height: 48px; width: auto;
    transition: filter 0.4s ease;
    opacity: 0;
    animation: logoFadeIn 1s ease 0.2s forwards;
  }
  @keyframes logoFadeIn {
    0% { opacity: 0; transform: translateY(-8px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  .nav-logo:hover {
    filter: drop-shadow(0 0 8px rgba(252,80,0,0.5)) drop-shadow(0 0 20px rgba(252,80,0,0.2));
  }

  /* ── Meta-bar (macOS-Menubar Style) ── */
  .nav-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    opacity: 0;
    animation: logoFadeIn 0.6s ease 1.5s forwards;
  }
  .nav-item {
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.65);
    font-variant-numeric: tabular-nums;
    transition: color 0.3s;
  }
  .nav-time { color: rgba(255,255,255,0.85); }
  .nav-sep {
    font-size: 9px;
    color: rgba(255,255,255,0.3);
    user-select: none;
  }
  .nav-sep-strong { color: rgba(255,255,255,0.4); margin: 0 2px; }

  .nav-toggle {
    border: none;
    background: transparent;
    cursor: pointer;
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 2px;
    color: rgba(255,255,255,0.7);
    transition: color 0.3s;
    padding: 4px 0;
  }
  .nav-toggle:hover { color: var(--orange); }

  .nav-cart {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    color: rgba(255,255,255,0.75);
    transition: color 0.25s, transform 0.25s;
    text-decoration: none;
  }
  .nav-cart svg {
    width: 18px;
    height: 18px;
    display: block;
  }
  .nav-cart:hover {
    color: var(--orange);
    transform: translateY(-1px);
  }
  .cart-dot {
    position: absolute;
    top: 1px; right: 0;
    width: 5px; height: 5px;
    border-radius: 50%;
    background: var(--orange);
    box-shadow: 0 0 0 0 rgba(252,80,0,0.55);
    animation: navPulse 2.4s ease-in-out infinite;
  }

  .nav-live-dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: var(--orange);
    box-shadow: 0 0 0 0 rgba(252,80,0,0.55);
    animation: navPulse 2.4s ease-in-out infinite;
    margin-left: 4px;
    flex-shrink: 0;
  }
  @keyframes navPulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(252,80,0,0.55); transform: scale(1); }
    50%      { box-shadow: 0 0 0 5px rgba(252,80,0,0); transform: scale(1.15); }
  }

  /* ── Light Mode ── */
  :global(body.light) .nav-item { color: rgba(0,0,0,0.65); text-shadow: 0 1px 6px rgba(255,255,255,0.6); }
  :global(body.light) .nav-time { color: rgba(0,0,0,0.85); }
  :global(body.light) .nav-sep { color: rgba(0,0,0,0.35); text-shadow: 0 1px 6px rgba(255,255,255,0.6); }
  :global(body.light) .nav-sep-strong { color: rgba(0,0,0,0.45); }
  :global(body.light) .nav-toggle { color: rgba(0,0,0,0.7); text-shadow: 0 1px 6px rgba(255,255,255,0.6); }
  :global(body.light) .nav-toggle:hover { color: var(--orange); }
  :global(body.light) .nav-cart { color: rgba(0,0,0,0.7); filter: drop-shadow(0 1px 6px rgba(255,255,255,0.6)); }
  :global(body.light) .nav-cart:hover { color: var(--orange); }

  @media (max-width: 700px) {
    nav { padding: 14px 1rem; }
    .nav-logo { height: 42px; }
    .nav-meta { gap: 5px; padding: 5px 10px; }
    .nav-item, .nav-toggle {
      font-size: 7px;
      letter-spacing: 1px;
      color: rgba(255,255,255,0.95);
    }
    .nav-time { color: #fff; }
    .nav-sep {
      font-size: 7px;
      color: rgba(255,255,255,0.55);
    }
    .nav-sep-strong { margin: 0 1px; color: rgba(255,255,255,0.65); }
    .nav-live-dot { width: 4px; height: 4px; margin-left: 2px; }
    .nav-cart { width: 18px; height: 18px; color: rgba(255,255,255,0.95); }
    .nav-cart svg { width: 15px; height: 15px; }
    .cart-dot { width: 4px; height: 4px; top: 0; right: -1px; }
  }
  @media (max-width: 380px) {
    nav { padding: 12px 0.75rem; }
    .nav-logo { height: 38px; }
    .nav-meta { gap: 4px; }
    .nav-item, .nav-toggle { font-size: 6.5px; letter-spacing: 0.8px; }
  }
</style>

<script>
  // ── Theme Toggle (disabled — dark mode only) ──
  (function() {
    document.body.classList.remove('light');
    document.documentElement.classList.remove('light-pre');
    try { localStorage.removeItem('wp_theme'); } catch(e) {}
  })();

  // ── Language Toggle ─────────────────────
  (function() {
    const btn = document.getElementById('langToggle');
    const KEY = 'wp_lang';
    let lang = localStorage.getItem(KEY) || 'de';
    if (lang !== 'de' && lang !== 'en') lang = 'de';
    if (btn) btn.textContent = lang.toUpperCase();
    document.documentElement.lang = lang;
    document.documentElement.setAttribute('data-lang', lang);

    btn?.addEventListener('click', () => {
      lang = (lang === 'de') ? 'en' : 'de';
      localStorage.setItem(KEY, lang);
      btn.textContent = lang.toUpperCase();
      document.documentElement.lang = lang;
      document.documentElement.setAttribute('data-lang', lang);
      // Trigger workspace i18n if loaded
      if ((window as any).WPi18n) (window as any).WPi18n.setLang(lang);
      window.dispatchEvent(new CustomEvent('wp:lang-changed', { detail: { lang } }));
      updateDate(); // refresh weekday/month abbrev
    });
  })();

  // ── Date & Time ─────────────────────────
  const dateEl = document.getElementById('navDate');
  const timeEl = document.getElementById('navTime');
  function getLang(): 'de' | 'en' {
    const l = localStorage.getItem('wp_lang') || 'de';
    return (l === 'en') ? 'en' : 'de';
  }
  const labels = {
    de: {
      days: ['SO','MO','DI','MI','DO','FR','SA'],
      months: ['JAN','FEB','MÄR','APR','MAI','JUN','JUL','AUG','SEP','OKT','NOV','DEZ']
    },
    en: {
      days: ['SUN','MON','TUE','WED','THU','FRI','SAT'],
      months: ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC']
    }
  };
  function updateDate() {
    if (!dateEl || !timeEl) return;
    const now = new Date();
    const L = labels[getLang()];
    dateEl.textContent = L.days[now.getDay()] + ' ' + String(now.getDate()).padStart(2,'0') + ' ' + L.months[now.getMonth()];
    timeEl.textContent = String(now.getHours()).padStart(2,'0') + ':' + String(now.getMinutes()).padStart(2,'0');
  }
  updateDate();
  setInterval(updateDate, 10000);

  // ── Weather (Open-Meteo, Rosenheim) ─────
  (function() {
    const wEl = document.getElementById('navWeather');
    if (!wEl) return;
    const WMO_DE: Record<number,string> = {0:'KLAR',1:'HEITER',2:'BEWÖLKT',3:'BEDECKT',45:'NEBEL',48:'NEBEL',51:'NIESEL',53:'NIESEL',55:'REGEN',61:'REGEN',63:'REGEN',65:'REGEN',71:'SCHNEE',73:'SCHNEE',75:'SCHNEE',80:'SCHAUER',81:'SCHAUER',82:'GEWITTER',95:'GEWITTER',96:'GEWITTER',99:'GEWITTER'};
    const WMO_EN: Record<number,string> = {0:'CLEAR',1:'FAIR',2:'CLOUDY',3:'OVERCAST',45:'FOG',48:'FOG',51:'DRIZZLE',53:'DRIZZLE',55:'RAIN',61:'RAIN',63:'RAIN',65:'RAIN',71:'SNOW',73:'SNOW',75:'SNOW',80:'SHOWERS',81:'SHOWERS',82:'STORM',95:'STORM',96:'STORM',99:'STORM'};
    let lastCode: number | null = null;
    let lastTemp: number | null = null;
    function paint() {
      if (!wEl || lastCode == null || lastTemp == null) return;
      const dict = getLang() === 'en' ? WMO_EN : WMO_DE;
      wEl.textContent = (dict[lastCode] || 'WX') + ' ' + Math.round(lastTemp) + '°';
    }
    // Map wttr.in description -> WMO-ish bucket so the existing dictionaries work
    function bucketFromDesc(desc: string): number {
      const d = desc.toLowerCase();
      if (/(thunder|storm|gewitter)/.test(d)) return 95;
      if (/(snow|schnee|sleet|blizzard)/.test(d)) return 71;
      if (/(shower|schauer)/.test(d)) return 80;
      if (/(drizzle|niesel)/.test(d)) return 51;
      if (/(rain|regen)/.test(d)) return 61;
      if (/(fog|mist|nebel|dunst|haze)/.test(d)) return 45;
      if (/(overcast|bedeckt)/.test(d)) return 3;
      if (/(cloud|bewölk|bewolk)/.test(d)) return 2;
      if (/(partly|fair|heiter)/.test(d)) return 1;
      if (/(clear|sunny|klar|sonnig)/.test(d)) return 0;
      return 2;
    }

    function tryOpenMeteo(): Promise<boolean> {
      return fetch('https://api.open-meteo.com/v1/forecast?latitude=47.856&longitude=12.129&current=temperature_2m,weather_code&timezone=Europe%2FBerlin')
        .then(r => r.ok ? r.json() : Promise.reject())
        .then(data => {
          if (!data?.current) return false;
          lastCode = data.current.weather_code;
          lastTemp = data.current.temperature_2m;
          paint();
          return true;
        })
        .catch(() => false);
    }

    function tryWttr(): Promise<boolean> {
      return fetch('https://wttr.in/Rosenheim?format=j1')
        .then(r => r.ok ? r.json() : Promise.reject())
        .then(data => {
          const cur = data?.current_condition?.[0];
          if (!cur) return false;
          lastTemp = parseFloat(cur.temp_C);
          lastCode = bucketFromDesc(cur.weatherDesc?.[0]?.value || '');
          paint();
          return true;
        })
        .catch(() => false);
    }

    (async () => {
      if (await tryOpenMeteo()) return;
      if (await tryWttr()) return;
      if (wEl) wEl.textContent = '—';
    })();
    window.addEventListener('wp:lang-changed', paint);
  })();
</script>
