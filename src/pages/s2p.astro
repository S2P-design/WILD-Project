---
// ═══════════════════════════════════════════════════
// S2P WORKSPACE — Shift2Pro Command Center
// ═══════════════════════════════════════════════════
// Privates Dashboard. Nicht verlinkt. Nur per URL erreichbar.
// Alles an einem Ort: Podcast, Buch, Content, Brand, Links.
// ═══════════════════════════════════════════════════

// ── PODCAST STATUS ──
type Episode = {
  nr: number;
  title: string;
  guest?: string;
  format: 'Long Shift' | 'Quick Shift' | 'The Bench' | 'Overtime';
  status: 'idea' | 'planned' | 'recorded' | 'edited' | 'published';
  date?: string;        // Release-Datum 'DD.MM.YYYY'
  pillar: 'inspire' | 'develop' | 'connect' | 'behind';
  notes?: string;
};

const episodes: Episode[] = [
  // Beispiel-Einträge — hier fortlaufend pflegen:
  // { nr: 1, title: 'Warum Shift2Pro', format: 'Quick Shift', status: 'idea', pillar: 'behind', notes: 'Persönliche Intro-Folge' },
  // { nr: 2, title: 'TBD', guest: 'TBD', format: 'Long Shift', status: 'idea', pillar: 'inspire' },
];

// ── BUCH STATUS ──
const bookStatus = {
  phase: 'Konzept',                  // 'Konzept' | 'Outline' | 'Schreibphase' | 'Layout' | 'Druck' | 'Launch'
  chapters: 8,
  chaptersWritten: 0,
  targetLaunch: 'Q4 2027',
  title: 'THE SHIFT',
};

// ── CONTENT PIPELINE ──
type ContentItem = {
  title: string;
  type: 'Reel' | 'Karussell' | 'Story' | 'Newsletter' | 'Blog' | 'YouTube';
  status: 'idea' | 'draft' | 'ready' | 'published';
  date?: string;
};

const contentPipeline: ContentItem[] = [];

// ── GÄSTE PIPELINE ──
type GuestEntry = {
  name: string;
  role: string;
  category: 'Legends' | 'Architects' | 'Innovators' | 'Next Gen' | 'Outsiders';
  status: 'wish' | 'contacted' | 'confirmed' | 'recorded' | 'published';
  notes?: string;
};

const guestPipeline: GuestEntry[] = [];

// ── HELPERS ──
const statusColor = (s: string) => {
  const map: Record<string, string> = {
    idea: '#555', planned: '#888', recorded: '#0CC0DF',
    edited: '#FC5000', published: '#4CAF50',
    wish: '#555', contacted: '#888', confirmed: '#0CC0DF',
    draft: '#888', ready: '#FC5000',
    'Konzept': '#555', 'Outline': '#888', 'Schreibphase': '#0CC0DF',
    'Layout': '#FC5000', 'Druck': '#FC5000', 'Launch': '#4CAF50',
  };
  return map[s] || '#555';
};

const now = new Date();
const pad = (n: number) => String(n).padStart(2, '0');
const dateStr = `${pad(now.getDate())}.${pad(now.getMonth()+1)}.${now.getFullYear()}`;

const totalEpisodes = episodes.length;
const publishedEps = episodes.filter(e => e.status === 'published').length;
const recordedEps = episodes.filter(e => e.status === 'recorded' || e.status === 'edited').length;
const confirmedGuests = guestPipeline.filter(g => g.status === 'confirmed' || g.status === 'recorded' || g.status === 'published').length;
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>S2P Workspace · Shift2Pro</title>
  <meta name="robots" content="noindex, nofollow">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Anton&family=Poppins:wght@300;400;600;700&family=JetBrains+Mono:wght@300;400;500;700&display=swap" rel="stylesheet">
</head>
<body>

<nav>
  <a href="/" class="nav-brand">
    <span class="nav-logo-text">S<span class="cyan">2</span>P</span>
  </a>
  <div class="nav-meta">
    <span class="nav-dot"></span>
    <span class="nav-status">WORKSPACE</span>
    <span class="nav-sep">&middot;</span>
    <span class="nav-date" id="navDate">{dateStr}</span>
  </div>
</nav>

<header class="hero">
  <div class="hero-eyebrow">
    <span class="dot"></span>
    SHIFT2PRO &middot; COMMAND CENTER
  </div>
  <h1>Work<span>space</span><span class="dot-orange">.</span></h1>
  <p class="tagline">Alles an einem Ort. Podcast. Buch. Content. Brand.</p>
  <div class="hero-pills">
    <span class="pill">INSPIRE</span>
    <span class="pill">DEVELOP</span>
    <span class="pill">CONNECT</span>
  </div>
</header>

<main class="page">

  <!-- ═══════════════════ STATUS OVERVIEW ═══════════════════ -->
  <section class="section">
    <div class="section-head">
      <div class="section-num">00</div>
      <h2>Status</h2>
      <span class="section-tag">&bull; Live Dashboard</span>
    </div>

    <div class="stat-grid">
      <div class="stat-card">
        <div class="stat-label">PODCAST</div>
        <div class="stat-value">{publishedEps}<span class="stat-unit">/{totalEpisodes || '—'}</span></div>
        <div class="stat-desc">Episoden ver&ouml;ffentlicht</div>
        <div class="stat-bar">
          <div class="stat-bar-fill" style={`width: ${totalEpisodes ? (publishedEps/totalEpisodes*100) : 0}%`}></div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-label">BUCH</div>
        <div class="stat-value">{bookStatus.chaptersWritten}<span class="stat-unit">/{bookStatus.chapters}</span></div>
        <div class="stat-desc">Kapitel &mdash; {bookStatus.phase}</div>
        <div class="stat-bar">
          <div class="stat-bar-fill" style={`width: ${bookStatus.chapters ? (bookStatus.chaptersWritten/bookStatus.chapters*100) : 0}%`}></div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-label">G&Auml;STE</div>
        <div class="stat-value">{confirmedGuests}<span class="stat-unit">/{guestPipeline.length || '—'}</span></div>
        <div class="stat-desc">Best&auml;tigt / Pipeline</div>
        <div class="stat-bar">
          <div class="stat-bar-fill" style={`width: ${guestPipeline.length ? (confirmedGuests/guestPipeline.length*100) : 0}%`}></div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-label">LAUNCH</div>
        <div class="stat-value stat-value-text">JUL 26</div>
        <div class="stat-desc">Podcast-Start geplant</div>
        <div class="stat-bar">
          <div class="stat-bar-fill stat-bar-cyan" style="width: 60%"></div>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════ EPISODEN-TRACKER ═══════════════════ -->
  <section class="section">
    <div class="section-head">
      <div class="section-num">01</div>
      <h2>Episoden</h2>
      <span class="section-tag">&bull; {totalEpisodes} total</span>
    </div>

    {episodes.length > 0 ? (
      <div class="episode-table">
        <div class="ep-header">
          <span class="ep-col-nr">#</span>
          <span class="ep-col-title">Titel</span>
          <span class="ep-col-format">Format</span>
          <span class="ep-col-pillar">Pillar</span>
          <span class="ep-col-status">Status</span>
        </div>
        {episodes.map(ep => (
          <div class="ep-row">
            <span class="ep-col-nr">{String(ep.nr).padStart(2, '0')}</span>
            <span class="ep-col-title">
              <span class="ep-title-text">{ep.title}</span>
              {ep.guest && <span class="ep-guest">mit {ep.guest}</span>}
            </span>
            <span class="ep-col-format">{ep.format}</span>
            <span class="ep-col-pillar">
              <span class={`pillar-dot pillar-${ep.pillar}`}></span>
              {ep.pillar}
            </span>
            <span class="ep-col-status">
              <span class="status-pill" style={`border-color: ${statusColor(ep.status)}; color: ${statusColor(ep.status)}`}>{ep.status}</span>
            </span>
          </div>
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <span class="empty-icon">01</span>
        <p>Noch keine Episoden eingetragen.</p>
        <p class="empty-hint">Pflege Episoden direkt in <code>s2p.astro</code> &rarr; <code>episodes[]</code></p>
      </div>
    )}
  </section>


  <!-- ═══════════════════ GÄSTE-PIPELINE ═══════════════════ -->
  <section class="section">
    <div class="section-head">
      <div class="section-num">02</div>
      <h2>G&auml;ste</h2>
      <span class="section-tag">&bull; Pipeline</span>
    </div>

    {guestPipeline.length > 0 ? (
      <div class="guest-grid">
        {guestPipeline.map(g => (
          <div class="guest-card">
            <div class="guest-cat">[{g.category.toUpperCase()}]</div>
            <div class="guest-name">{g.name}</div>
            <div class="guest-role">{g.role}</div>
            <span class="status-pill" style={`border-color: ${statusColor(g.status)}; color: ${statusColor(g.status)}`}>{g.status}</span>
            {g.notes && <div class="guest-notes">{g.notes}</div>}
          </div>
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <span class="empty-icon">02</span>
        <p>Noch keine G&auml;ste eingetragen.</p>
        <p class="empty-hint">Pflege G&auml;ste in <code>s2p.astro</code> &rarr; <code>guestPipeline[]</code></p>
      </div>
    )}
  </section>


  <!-- ═══════════════════ BUCH ═══════════════════ -->
  <section class="section">
    <div class="section-head">
      <div class="section-num">03</div>
      <h2>{bookStatus.title}</h2>
      <span class="section-tag">&bull; {bookStatus.phase}</span>
    </div>

    <div class="book-overview">
      <div class="book-meta-grid">
        <div class="book-meta-cell">
          <span class="book-meta-label">FORMAT</span>
          <span class="book-meta-value">Hardcover &middot; Fadenheftung</span>
        </div>
        <div class="book-meta-cell">
          <span class="book-meta-label">UMFANG</span>
          <span class="book-meta-value">200&ndash;260 Seiten</span>
        </div>
        <div class="book-meta-cell">
          <span class="book-meta-label">LAUNCH</span>
          <span class="book-meta-value cyan">{bookStatus.targetLaunch}</span>
        </div>
        <div class="book-meta-cell">
          <span class="book-meta-label">PHASE</span>
          <span class="book-meta-value" style={`color: ${statusColor(bookStatus.phase)}`}>{bookStatus.phase}</span>
        </div>
      </div>

      <div class="book-chapters">
        <div class="book-chapters-label">KAPITEL</div>
        <div class="book-chapter-bar">
          {Array.from({length: bookStatus.chapters}).map((_, i) => (
            <div class={`chapter-block ${i < bookStatus.chaptersWritten ? 'written' : ''}`}>
              {String(i).padStart(2, '0')}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════ QUICK LINKS ═══════════════════ -->
  <section class="section">
    <div class="section-head">
      <div class="section-num">04</div>
      <h2>Quick Links</h2>
      <span class="section-tag">&bull; Alles griffbereit</span>
    </div>

    <div class="links-grid">
      <a href="https://www.instagram.com/shift2pro" target="_blank" rel="noopener" class="link-card">
        <span class="link-icon">IG</span>
        <span class="link-title">Instagram</span>
        <span class="link-desc">@shift2pro</span>
      </a>
      <a href="https://www.tiktok.com/@shift2pro" target="_blank" rel="noopener" class="link-card">
        <span class="link-icon">TT</span>
        <span class="link-title">TikTok</span>
        <span class="link-desc">@shift2pro</span>
      </a>
      <a href="https://www.youtube.com/@shift2pro" target="_blank" rel="noopener" class="link-card">
        <span class="link-icon">YT</span>
        <span class="link-title">YouTube</span>
        <span class="link-desc">@shift2pro</span>
      </a>
      <a href="https://www.shift2pro.com" target="_blank" rel="noopener" class="link-card">
        <span class="link-icon">WEB</span>
        <span class="link-title">Website</span>
        <span class="link-desc">shift2pro.com</span>
      </a>
      <a href="https://hedzup.store/shop?category=pcol_01KNVP0MMRES38MJ9C5QG6XZCB" target="_blank" rel="noopener" class="link-card">
        <span class="link-icon">HU</span>
        <span class="link-title">Merch Store</span>
        <span class="link-desc">hedzup.store</span>
      </a>
      <a href="/shop" class="link-card">
        <span class="link-icon">WP</span>
        <span class="link-title">WP Shop</span>
        <span class="link-desc">wildproject.pro/shop</span>
      </a>
    </div>
  </section>


  <!-- ═══════════════════ BRAND QUICK REF ═══════════════════ -->
  <section class="section">
    <div class="section-head">
      <div class="section-num">05</div>
      <h2>Brand</h2>
      <span class="section-tag">&bull; Quick Reference</span>
    </div>

    <div class="brand-ref">
      <div class="brand-colors">
        <div class="brand-swatch" style="background:#0CC0DF;">
          <span class="swatch-label">Shift Cyan</span>
          <span class="swatch-hex">#0CC0DF</span>
        </div>
        <div class="brand-swatch" style="background:#000000; border:1px solid #222;">
          <span class="swatch-label" style="color:#888;">Blackout</span>
          <span class="swatch-hex" style="color:#666;">#000000</span>
        </div>
        <div class="brand-swatch" style="background:#DBDBDB;">
          <span class="swatch-label" style="color:#333;">Ice Light</span>
          <span class="swatch-hex" style="color:#555;">#DBDBDB</span>
        </div>
        <div class="brand-swatch" style="background:#FC5000;">
          <span class="swatch-label">WP Orange</span>
          <span class="swatch-hex">#FC5000</span>
        </div>
      </div>

      <div class="brand-fonts">
        <div class="font-specimen">
          <span class="font-name">Anton</span>
          <span class="font-sample" style="font-family:'Anton',sans-serif; font-size:1.8rem;">SHIFT2PRO</span>
          <span class="font-use">Display &middot; Headlines</span>
        </div>
        <div class="font-specimen">
          <span class="font-name">Poppins</span>
          <span class="font-sample" style="font-family:'Poppins',sans-serif; font-size:1.1rem; font-weight:300;">Inspire. Develop. Connect.</span>
          <span class="font-use">Body &middot; 80%</span>
        </div>
        <div class="font-specimen">
          <span class="font-name">JetBrains Mono</span>
          <span class="font-sample" style="font-family:'JetBrains Mono',monospace; font-size:0.85rem;">[S2P] WORKSPACE &middot; 2026</span>
          <span class="font-use">Labels &middot; Meta &middot; 15%</span>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════ MASTERPLAN ═══════════════════ -->
  <section class="section">
    <div class="section-head">
      <div class="section-num">06</div>
      <h2>Strategie</h2>
      <span class="section-tag">&bull; Dokumente</span>
    </div>

    <div class="doc-grid">
      <a href="/s2p-masterplan" class="doc-card" target="_blank">
        <div class="doc-icon">MP</div>
        <div class="doc-info">
          <div class="doc-title">Shift2Pro Masterplan</div>
          <div class="doc-desc">Brand &middot; Business &middot; Marketing &middot; Content &middot; Podcast &middot; Buch</div>
        </div>
        <span class="doc-arrow">&rarr;</span>
      </a>
      <a href="/basecamp" class="doc-card">
        <div class="doc-icon">BC</div>
        <div class="doc-info">
          <div class="doc-title">Wild Project Basecamp</div>
          <div class="doc-desc">Brand Assets &amp; Press Kit der Dachmarke</div>
        </div>
        <span class="doc-arrow">&rarr;</span>
      </a>
    </div>
  </section>


  <!-- ═══════════════════ WEBSITE ═══════════════════ -->
  <section class="section">
    <div class="section-head">
      <div class="section-num">07</div>
      <h2>Website</h2>
      <span class="section-tag">&bull; shift2pro.com</span>
    </div>

    <div class="doc-grid">
      <a href="https://www.shift2pro.com" target="_blank" rel="noopener" class="doc-card">
        <div class="doc-icon" style="color: #4CAF50;">CS</div>
        <div class="doc-info">
          <div class="doc-title">Coming Soon <span class="status-pill" style="border-color: #4CAF50; color: #4CAF50; margin-left: 0.5rem; font-size: 0.65rem;">LIVE</span></div>
          <div class="doc-desc">Aktuelle Landing Page &mdash; shift2pro.com</div>
        </div>
        <span class="doc-arrow">&rarr;</span>
      </a>
      <a href="https://github.com/Innsiders/shift2pro" target="_blank" rel="noopener" class="doc-card">
        <div class="doc-icon">GH</div>
        <div class="doc-info">
          <div class="doc-title">Repo <span class="status-pill" style="border-color: var(--cyan); color: var(--cyan); margin-left: 0.5rem; font-size: 0.65rem;">Innsiders</span></div>
          <div class="doc-desc">GitHub &mdash; Innsiders/shift2pro</div>
        </div>
        <span class="doc-arrow">&rarr;</span>
      </a>
      <a href="http://localhost:4322" target="_blank" rel="noopener" class="doc-card">
        <div class="doc-icon" style="color: var(--orange);">DEV</div>
        <div class="doc-info">
          <div class="doc-title">Hauptseite <span class="status-pill" style="border-color: var(--orange); color: var(--orange); margin-left: 0.5rem; font-size: 0.65rem;">IN DEV</span></div>
          <div class="doc-desc">Lokale Entwicklung &mdash; localhost:4322</div>
        </div>
        <span class="doc-arrow">&rarr;</span>
      </a>
    </div>
  </section>

</main>


<footer>
  <div class="footer-inner">
    <span class="footer-brand">S<span class="cyan">2</span>P &middot; Workspace</span>
    <span class="footer-note">Privates Dashboard &mdash; nicht &ouml;ffentlich verlinkt</span>
    <span class="footer-wp">A <span style="color:#FC5000;">Wild Project</span> Product</span>
  </div>
</footer>

<style>
/* ═══════════════════════════════════════
   S2P WORKSPACE — STYLES
   ═══════════════════════════════════════ */
:root {
  --black:   #000000;
  --surface: #060606;
  --border:  #1a1a1a;
  --border2: #222;
  --muted:   #555;
  --text:    #888;
  --light:   #ccc;
  --white:   #f0f0f0;
  --cyan:    #0CC0DF;
  --cyan-20: rgba(12,192,223,0.20);
  --cyan-10: rgba(12,192,223,0.10);
  --cyan-05: rgba(12,192,223,0.05);
  --orange:  #FC5000;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  background: var(--black);
  color: var(--text);
  font-family: 'Poppins', -apple-system, sans-serif;
  font-weight: 300;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}
.cyan { color: var(--cyan); }

/* ── NAV ── */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 3rem; height: 56px;
  background: rgba(0,0,0,0.92);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border);
}
nav::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, var(--cyan), rgba(12,192,223,0.2) 50%, transparent);
}
.nav-brand { text-decoration: none; }
.nav-logo-text {
  font-family: 'Anton', sans-serif;
  font-size: 1.3rem; color: var(--white); letter-spacing: 1px;
}
.nav-meta {
  display: flex; align-items: center; gap: 8px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 9px; letter-spacing: 1.5px; color: var(--muted);
}
.nav-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--cyan);
  box-shadow: 0 0 8px rgba(12,192,223,0.4);
  animation: pulse 2.4s ease-in-out infinite;
}
.nav-sep { color: var(--border2); }
@keyframes pulse {
  0%,100% { box-shadow: 0 0 0 0 rgba(12,192,223,0.5); }
  50% { box-shadow: 0 0 0 5px rgba(12,192,223,0); }
}

/* ── HERO ── */
.hero {
  max-width: 900px; margin: 0 auto;
  padding: 100px 3rem 48px;
}
.hero-eyebrow {
  display: inline-flex; align-items: center; gap: 10px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px; letter-spacing: 2px; color: var(--muted);
  padding: 6px 12px; border: 1px solid var(--border);
  margin-bottom: 28px;
}
.hero-eyebrow .dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--cyan); animation: pulse 2.4s ease-in-out infinite;
}
.hero h1 {
  font-family: 'Anton', sans-serif;
  font-size: clamp(3rem, 9vw, 5.5rem);
  font-weight: 400; color: var(--white);
  line-height: 0.95; letter-spacing: -1px;
}
.hero h1 span { color: var(--cyan); }
.dot-orange { color: var(--orange) !important; }
.tagline {
  font-size: 1rem; color: var(--text);
  margin: 16px 0 20px; max-width: 500px;
}
.hero-pills { display: flex; gap: 8px; }
.pill {
  font-family: 'JetBrains Mono', monospace;
  font-size: 9px; font-weight: 500; letter-spacing: 1.5px;
  padding: 4px 10px; border: 1px solid var(--cyan-20); color: var(--cyan);
}

/* ── PAGE ── */
.page { max-width: 900px; margin: 0 auto; padding: 0 3rem 80px; }

/* ── SECTIONS ── */
.section { margin-bottom: 64px; }
.section-head {
  display: flex; align-items: baseline; gap: 14px;
  margin-bottom: 28px; padding-bottom: 12px;
  border-bottom: 1px solid var(--border);
}
.section-num {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px; font-weight: 600; letter-spacing: 1.5px;
  color: var(--cyan); padding: 4px 8px;
  border: 1px solid var(--cyan-20);
  background: var(--cyan-05);
}
.section-head h2 {
  font-family: 'Anton', sans-serif;
  font-size: clamp(1.3rem, 2.5vw, 1.7rem);
