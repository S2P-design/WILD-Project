---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

// ═══════════════════════════════════════════════════
// SHOP — Merch, Digitale Produkte & Drops
// ═══════════════════════════════════════════════════

// 1) MERCH COLLECTION — Hedz.Up Kollektion
//    Produkte manuell pflegen. href → hedzup.store
//
type MerchItem = {
  title: string;
  type: string;        // 'HOODIE' · 'TEE' · 'CAP' · …
  desc: string;
  descEn?: string;
  price: string;
  href: string;
  badge?: string;      // 'NEW' · 'LIMITED' · 'SOLD OUT'
  soldOut?: boolean;
};
const merchItems: MerchItem[] = [
  {
    title: 'Oversize Hoodie — Blackout',
    type: 'HOODIE',
    desc: 'Schwerer 400gsm Baumwoll-Fleece. Oversized Fit. Minimales Branding.',
    descEn: 'Heavy 400gsm cotton fleece. Oversized fit. Minimal branding.',
    price: 'ab 69 €',
    href: 'https://hedzup.store/shop?category=pcol_01KNVP0MMRES38MJ9C5QG6XZCB',
    badge: 'NEW',
  },
  {
    title: 'Oversize Tee — Ice White',
    type: 'TEE',
    desc: '240gsm Premium-Cotton. Drop-Shoulder. Clean.',
    descEn: '240gsm premium cotton. Drop-shoulder. Clean.',
    price: 'ab 39 €',
    href: 'https://hedzup.store/shop?category=pcol_01KNVP0MMRES38MJ9C5QG6XZCB',
    badge: 'NEW',
  },
  {
    title: 'Snapback Cap — Stealth',
    type: 'CAP',
    desc: 'Unstrukturiert. Ton-in-Ton-Stickerei. Passt immer.',
    descEn: 'Unstructured. Tonal embroidery. Always fits.',
    price: 'ab 34 €',
    href: 'https://hedzup.store/shop?category=pcol_01KNVP0MMRES38MJ9C5QG6XZCB',
  },
];

// 2) NEXT DROP
const nextDropDate: string | null = null;
const nextDropTitle: string | null = null;

// 3) DIGITALE PRODUKTE
type DigitalProduct = {
  code: string;
  title: string;
  type: string;
  desc: string;
  price: string;
  href: string;
};
const digitalProducts: DigitalProduct[] = [];
// ═══════════════════════════════════════════════════
---

<Layout
  title="Shop · Wild Project"
  description="Wild Project Shop — Casual Streetwear mit Eishockey-DNA von Hedz.Up. Limitierte Drops, digitale Produkte und Sachen, die glücklich machen."
  path="/shop"
>

<Nav />

<header class="hero">
  <div class="hero-eyebrow">
    <span class="dot"></span>
    SHOP &middot; WP/26
  </div>
  <h1>Shop<span>.</span></h1>
  <p class="tagline"><span class="t-de">Weniger ist mehr. Au&szlig;er bei Qualit&auml;t.</span><span class="t-en">Less is more. Except for quality.</span></p>
  <div class="hero-statement">
    <span class="br">[</span>WEAR<span class="br">]</span>
    <span class="br">[</span>SUPPORT<span class="br">]</span>
    <span class="br">[</span>WILD<span class="br">]</span>
  </div>
</header>

<main class="page">

  <!-- ═══════════════════ MERCH — HEDZ.UP COLLAB ═══════════════════ -->
  <section class="merch-section">
    <div class="drop-head">
      <div class="drop-num">N&deg;01</div>
      <h2>Merch</h2>
      <span class="drop-status">&bull; {merchItems.length} <span class="t-de">verf&uuml;gbar</span><span class="t-en">available</span></span>
    </div>

    <div class="collab-bar">
      <div class="collab-left">
        <span class="collab-label"><span class="t-de">Kollektion von</span><span class="t-en">Collection by</span></span>
        <span class="collab-brand">HEDZ.UP</span>
      </div>
      <div class="collab-right">
        <span class="collab-tag">Casual Streetwear &middot; Eishockey DNA</span>
      </div>
    </div>

    <p class="section-intro">
      <span class="t-de">Kein Merch-Bauchladen. Ausgew&auml;hlte St&uuml;cke, die du wirklich tragen willst &mdash; designed von <a href="https://hedzup.store" target="_blank" rel="noopener">Hedz.Up</a>.</span>
      <span class="t-en">No merch clutter. Pieces you actually want to wear &mdash; designed by <a href="https://hedzup.store" target="_blank" rel="noopener">Hedz.Up</a>.</span>
    </p>

    <div class="merch-grid">
      {merchItems.map((item, i) => (
        <a href={item.href} target="_blank" rel="noopener" class={`merch-card ${item.soldOut ? 'sold-out' : ''}`}>
          <span class="corner tl"></span>
          <span class="corner tr"></span>
          <span class="corner bl"></span>
          <span class="corner br"></span>

          <div class="merch-top">
            <span class="merch-type">[{item.type}]</span>
            {item.badge && <span class={`merch-badge ${item.badge.toLowerCase().replace(' ', '-')}`}>{item.badge}</span>}
          </div>

          <div class="merch-icon-area">
            <div class="merch-icon-placeholder">
              <span class="merch-num">{String(i + 1).padStart(2, '0')}</span>
            </div>
          </div>

          <h3 class="merch-title">{item.title}</h3>
          <p class="merch-desc">
            <span class="t-de">{item.desc}</span>
            {item.descEn && <span class="t-en">{item.descEn}</span>}
          </p>

          <div class="merch-foot">
            <span class="merch-price">{item.price}</span>
            <span class="merch-cta">
              {item.soldOut ? 'SOLD OUT' : 'SHOP →'}
            </span>
          </div>
        </a>
      ))}
    </div>

    <a href="https://hedzup.store/shop?category=pcol_01KNVP0MMRES38MJ9C5QG6XZCB" target="_blank" rel="noopener" class="store-link">
      <span class="store-link-inner">
        <span class="store-link-label"><span class="t-de">Gesamte Kollektion auf</span><span class="t-en">Full collection on</span></span>
        <span class="store-link-brand">hedzup.store</span>
        <span class="store-link-arrow">&rarr;</span>
      </span>
    </a>

    <div class="promo-banner">
      <div class="promo-inner">
        <span class="promo-code">ROOKIE10</span>
        <span class="promo-text"><span class="t-de">10 % auf deine erste Bestellung</span><span class="t-en">10% off your first order</span></span>
      </div>
    </div>
  </section>


  <!-- ═══════════════════ DROPS ═══════════════════ -->
  <section class="drop-section">
    <div class="drop-head">
      <div class="drop-num">N&deg;02</div>
      <h2>Drops</h2>
      <span class="drop-status">&bull; {nextDropDate ? 'scheduled' : 'in preparation'}</span>
    </div>
    <p class="section-intro">
      <span class="t-de">Limitierte St&uuml;cke. Wenn weg, dann weg.</span>
      <span class="t-en">Limited pieces. Once gone, gone for good.</span>
      <span class="intro-tags">[ CAPSULE &middot; COLLABS &middot; SPECIALS ]</span>
    </p>

    <div class="drop-card">
      <span class="corner tl"></span>
      <span class="corner tr"></span>
      <span class="corner bl"></span>
      <span class="corner br"></span>

      <div class="drop-eyebrow">
        <span class="dot"></span>
        {nextDropDate ? '[NEXT DROP]' : '[COMING SOON]'}
      </div>

      {nextDropDate ? (
        <>
          <div class="drop-date">{nextDropDate}</div>
          {nextDropTitle && <div class="drop-title">{nextDropTitle}</div>}
          <p class="drop-desc">
            <span class="t-de">Limitiert. Newsletter zuerst.</span>
            <span class="t-en">Limited. Newsletter first.</span>
          </p>
        </>
      ) : (
        <>
          <div class="drop-coming">DROP&nbsp;01</div>
          <p class="drop-desc">
            <span class="t-de">Kommt. Wann genau? Folge <a href="https://www.instagram.com/wild_projects" target="_blank" rel="noopener">@wild_projects</a> und du erf&auml;hrst es zuerst.</span>
            <span class="t-en">Coming. When exactly? Follow <a href="https://www.instagram.com/wild_projects" target="_blank" rel="noopener">@wild_projects</a> and you'll know first.</span>
          </p>
        </>
      )}

      <div class="drop-meta">
        <span>[CAPSULE]</span>
        <span class="sep">&middot;</span>
        <span>[COLLABS]</span>
        <span class="sep">&middot;</span>
        <span>[SPECIALS]</span>
      </div>
    </div>
  </section>


  <!-- ═══════════════════ DIGITALE PRODUKTE ═══════════════════ -->
  <section class="dp-section">
    <div class="drop-head">
      <div class="drop-num">N&deg;03</div>
      <h2><span class="t-de">Digitale Produkte</span><span class="t-en">Digital Products</span></h2>
      <span class="drop-status">&bull; {digitalProducts.length > 0 ? `${digitalProducts.length}` : 'in preparation'}</span>
    </div>
    <p class="section-intro">
      <span class="t-de">Sachen f&uuml;r den Kopf. Einmal kaufen. F&uuml;r immer dein.</span>
      <span class="t-en">Fuel for the mind. Buy once. Keep forever.</span>
      <span class="intro-tags">[ WORKBOOKS &middot; WALLPAPERS &middot; BLUEPRINTS ]</span>
    </p>

    {digitalProducts.length > 0 ? (
      <div class="dp-grid">
        {digitalProducts.map((p) => (
          <a href={p.href} class="dp-card">
            <span class="corner tl"></span>
            <span class="corner tr"></span>
            <span class="corner bl"></span>
            <span class="corner br"></span>
            <div class="dp-code">{p.code}</div>
            <div class="dp-type">[{p.type.toUpperCase()}]</div>
            <h3 class="dp-title">{p.title}</h3>
            <p class="dp-desc">{p.desc}</p>
            <div class="dp-foot">
              <span class="dp-price">{p.price}</span>
              <span class="dp-cta">Ansehen &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="dp-empty">
        <span class="corner tl"></span>
        <span class="corner tr"></span>
        <span class="corner bl"></span>
        <span class="corner br"></span>
        <div class="drop-eyebrow">
          <span class="dot"></span>
          [COMING SOON]
        </div>
        <div class="drop-coming">IN&nbsp;ARBEIT</div>
        <p class="drop-desc">
          <span class="t-de">Workbooks, Wallpapers, Blueprints.<br>Gut Ding braucht Weile.</span>
          <span class="t-en">Workbooks, wallpapers, blueprints.<br>Good things take time.</span>
        </p>
        <div class="drop-meta">
          <span>[WORKBOOKS]</span>
          <span class="sep">&middot;</span>
          <span>[WALLPAPERS]</span>
          <span class="sep">&middot;</span>
          <span>[BLUEPRINTS]</span>
        </div>
      </div>
    )}
  </section>

</main>

<Footer tagline="YES, YOU CAN BUY LOVE." taglineSteps={22} taglineWidthEm={17.6} />

</Layout>

<style>
  /* ── BACKGROUND ──────────────────── */
  body {
    background-color: #000000;
    background-image:
      radial-gradient(circle at 1px 1px, rgba(255,255,255,0.06) 1px, transparent 1.5px);
    background-size: 24px 24px;
    background-attachment: fixed;
  }

  /* ── HERO ────────────────────────── */
  .hero {
    max-width: 1100px;
    margin: 0 auto;
    padding: 72px 3rem 40px;
    position: relative;
  }
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    padding: 6px 12px;
    border: 1px solid rgba(255,255,255,0.08);
    background: rgba(255,255,255,0.02);
    margin-bottom: 28px;
  }
  .hero-eyebrow .dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--orange);
    animation: heroPulse 2.4s ease-in-out infinite;
  }
  @keyframes heroPulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(252,80,0,0.55); transform: scale(1); }
    50%      { box-shadow: 0 0 0 6px rgba(252,80,0,0); transform: scale(1.15); }
  }
  .hero h1 {
    font-size: clamp(3rem, 9vw, 6rem);
    font-weight: 700;
    letter-spacing: -3px;
    line-height: 0.95;
    color: var(--white);
    margin: 0 0 14px;
  }
  .hero h1 span { color: var(--orange); }
  .hero .tagline {
    font-size: clamp(1rem, 1.6vw, 1.15rem);
    color: var(--grey-mid);
    font-style: italic;
    margin: 0 0 20px;
    max-width: 620px;
  }
  .hero-statement {
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: clamp(10px, 1vw, 12px);
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.85);
    margin-top: 10px;
  }
  .hero-statement .br {
    color: var(--orange);
    font-weight: 400;
    margin: 0 2px;
  }

  /* ── PAGE WRAP ───────────────────── */
  .page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 20px 3rem 100px;
  }

  /* ── SECTIONS ────────────────────── */
  .merch-section,
  .dp-section,
  .drop-section {
    margin-bottom: 80px;
    position: relative;
  }

  .drop-head {
    display: flex;
    align-items: baseline;
    gap: 14px;
    margin-bottom: 32px;
    padding-bottom: 14px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .drop-num {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.5px;
    color: var(--orange);
    padding: 4px 8px;
    border: 1px solid rgba(252,80,0,0.35);
    background: rgba(252,80,0,0.06);
  }
  .drop-head h2 {
    font-size: clamp(1.4rem, 2.6vw, 1.85rem);
    font-weight: 600;
    letter-spacing: -0.5px;
    color: var(--white);
    margin: 0;
  }
  .drop-status {
    margin-left: auto;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 9px;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
  }
  .section-intro {
    font-size: 13.5px;
    line-height: 1.7;
    color: var(--grey-mid);
    max-width: 720px;
    margin: 0 0 28px;
  }
  .section-intro a { color: var(--orange); text-decoration: none; }
  .section-intro a:hover { text-decoration: underline; }
  .section-intro .intro-tags {
    display: block;
    margin-top: 6px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10px;
    letter-spacing: 1.8px;
    color: var(--orange);
  }

  /* ── COLLAB BAR ──────────────────── */
  .collab-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 20px;
    background: rgba(252,80,0,0.04);
    border: 1px solid rgba(252,80,0,0.12);
    margin-bottom: 24px;
    gap: 16px;
  }
  .collab-left {
    display: flex;
    align-items: baseline;
    gap: 10px;
  }
  .collab-label {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 9px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
  }
  .collab-brand {
    font-family: 'Poppins', system-ui, sans-serif;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 2px;
    color: var(--white);
  }
  .collab-tag {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 9px;
    letter-spacing: 1.2px;
    color: rgba(255,255,255,0.35);
    white-space: nowrap;
  }

  /* ── MERCH GRID ──────────────────── */
  .merch-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
    margin-bottom: 28px;
  }
  .merch-card {
    position: relative;
    background: #0a0a0a;
    border: 1px solid rgba(255,255,255,0.08);
    padding: 28px 24px 24px;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 0;
    transition: border-color 0.3s, transform 0.3s, box-shadow 0.3s;
    overflow: hidden;
  }
  .merch-card::before {
    content: '';
    position: absolute;
    left: 0; right: 0; top: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--orange), rgba(252,80,0,0.1));
    opacity: 0;
    transition: opacity 0.3s;
  }
  .merch-card:hover {
    border-color: rgba(252,80,0,0.35);
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.4), 0 0 0 1px rgba(252,80,0,0.08);
  }
  .merch-card:hover::before { opacity: 1; }
  .merch-card.sold-out { opacity: 0.5; pointer-events: none; }

  .merch-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
  }
  .merch-type {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--orange);
    font-weight: 600;
  }
  .merch-badge {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 8px;
    font-weight: 700;
    letter-spacing: 1.5px;
    padding: 3px 8px;
    text-transform: uppercase;
  }
  .merch-badge.new {
    color: var(--orange);
    border: 1px solid rgba(252,80,0,0.35);
    background: rgba(252,80,0,0.08);
  }
  .merch-badge.limited {
    color: #fff;
    border: 1px solid rgba(255,255,255,0.2);
    background: rgba(255,255,255,0.06);
  }
  .merch-badge.sold-out {
    color: rgba(255,255,255,0.4);
    border: 1px solid rgba(255,255,255,0.1);
  }

  /* Icon placeholder area */
  .merch-icon-area {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 28px 0;
    margin-bottom: 16px;
    border-top: 1px solid rgba(255,255,255,0.04);
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }
  .merch-icon-placeholder {
    width: 72px;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255,255,255,0.06);
    position: relative;
  }
  .merch-num {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 1.6rem;
    font-weight: 600;
    color: rgba(255,255,255,0.08);
    font-variant-numeric: tabular-nums;
    transition: color 0.3s;
  }
  .merch-card:hover .merch-num { color: rgba(252,80,0,0.2); }

  .merch-title {
    font-family: 'Poppins', system-ui, sans-serif;
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: -0.3px;
    color: var(--white);
    margin: 0 0 8px;
    line-height: 1.25;
  }
  .merch-desc {
    font-size: 12.5px;
    line-height: 1.6;
    color: var(--grey-mid);
    margin: 0 0 auto;
    padding-bottom: 16px;
  }
  .merch-foot {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-top: 14px;
    border-top: 1px solid rgba(255,255,255,0.06);
  }
  .merch-price {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 1rem;
    font-weight: 600;
    color: var(--white);
    font-variant-numeric: tabular-nums;
  }
  .merch-cta {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10px;
    letter-spacing: 1.5px;
    color: var(--orange);
    text-transform: uppercase;
    transition: transform 0.3s;
  }
  .merch-card:hover .merch-cta { transform: translateX(3px); }

  /* ── STORE LINK ──────────────────── */
  .store-link {
    display: block;
    text-decoration: none;
    margin-bottom: 16px;
  }
  .store-link-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 18px 28px;
    background: rgba(252,80,0,0.04);
    border: 1px solid rgba(252,80,0,0.15);
    transition: all 0.3s;
  }
  .store-link:hover .store-link-inner {
    background: rgba(252,80,0,0.08);
    border-color: rgba(252,80,0,0.35);
    transform: translateY(-1px);
  }
  .store-link-label {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 9px;
    letter-spacing: 1.5px;
    color: rgba(255,255,255,0.4);
    text-transform: uppercase;
  }
  .store-link-brand {
    font-family: 'Poppins', system-ui, sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--white);
    letter-spacing: 0.5px;
  }
  .store-link-arrow {
    color: var(--orange);
    font-size: 1.1rem;
    transition: transform 0.3s;
  }
  .store-link:hover .store-link-arrow { transform: translateX(4px); }

  /* ── PROMO BANNER ────────────────── */
  .promo-banner {
    margin-top: 0;
  }
  .promo-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    padding: 14px 24px;
    border: 1px dashed rgba(255,255,255,0.1);
    background: rgba(255,255,255,0.02);
  }
  .promo-code {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 3px;
    color: var(--orange);
    padding: 4px 12px;
    border: 1px solid rgba(252,80,0,0.3);
    background: rgba(252,80,0,0.06);
  }
  .promo-text {
    font-size: 12px;
    color: rgba(255,255,255,0.5);
    letter-spacing: 0.5px;
  }

