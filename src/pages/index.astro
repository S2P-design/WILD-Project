    .links-label { margin-bottom: 8px; font-size: 9px; letter-spacing: 2px; }

    /* Connector + contact */
    .connector-line { padding: 16px 0; }
    .connector-line.visible .connector-line-inner { height: 32px; }
    .contact-row {
      flex-direction: column;
