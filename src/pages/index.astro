    .about-toggle-icon { width: 20px; height: 20px; font-size: 12px; }
    .about-text { font-size: 12px; line-height: 1.55; }
    .about-list { font-size: 12px; line-height: 1.55; margin-top: 10px; }
    .about-signoff { font-size: 12px; line-height: 1.55; margin-top: 16px; }
    .about-footnote { font-size: 10px; margin-top: 22px; }

    /* Links */
