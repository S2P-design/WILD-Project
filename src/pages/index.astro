---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import LinkItem from '../components/LinkItem.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="René Wild — Eishockeytrainer & Development Coach | Wild Project"
  description="René Wild — Development Coach der Starbulls Rosenheim, Host des Shift2Pro Podcasts und Ästhetik Junkie. 30+ Jahre Eishockey, ganzheitliche Spielerentwicklung und Coaching aus Rosenheim."
  path="/"
>
  <div class="page-bg"></div>

  <div class="page-content">
    <Nav />
    <Hero />

    <div class="lower">
      <!-- CTA ROW -->
      <div class="cta-row">
        <a href="mailto:rene@wildproject.pro?subject=Let%27s%20collab%20%E2%80%94%20wildproject.pro" class="cta cta-primary">
          <span>Let&rsquo;s collab</span>
          <span class="cta-arrow">→</span>
        </a>
        <a href="https://www.shift2pro.com" target="_blank" rel="noopener" class="cta cta-ghost">
          <span>Shift2Pro hören</span>
          <span class="cta-arrow">↗</span>
        </a>
      </div>

      <!-- ABOUT (collapsible) -->
      <div class="about-toggle" id="aboutToggle">
        <span class="about-toggle-label">Über mich</span>
        <span class="about-toggle-icon">+</span>
      </div>
      <div class="about-body" id="aboutBody">
        <div class="about-body-inner">
          <p class="about-text">Ich bin René Wild — professioneller Nachwuchs-Eishockeytrainer, stolzer Papa und bekennender Aesthetic-Junkie. Als Development Coach der Starbulls Rosenheim begleite ich täglich die Entwicklung junger Talente.</p>
          <p class="about-text">Heute verbinde ich Coaching, Consulting und eigene Projekte zu einem ganzheitlichen Ansatz, der Spieler, Teams und Organisationen nachhaltig weiterbringt.</p>
          <div class="about-stats">
            <div class="stat">
              <div class="stat-number">30+</div>
              <div class="stat-label">Jahre Erfahrung</div>
            </div>
            <a href="https://www.eliteprospects.com/staff/45114/rene-wild" target="_blank" rel="noopener" class="stat stat-link">
              <div class="stat-number">EP</div>
              <div class="stat-label">Elite Prospects</div>
            </a>
          </div>
        </div>
      </div>

      <!-- LINKTREE -->
      <div class="links-section">
        <div class="links-label">Projekte</div>
        <LinkItem href="https://www.shift2pro.com" icon="S2P" title="Shift2Pro" desc="Podcast — Inspire · Develop · Connect" />
        <LinkItem href="https://www.sbr-nachwuchs.de/" icon="SBR" title="Starbulls Rosenheim e.V." desc="Ausbildungshochburg seit Jahrzehnten — eine der stärksten Nachwuchsorganisationen Deutschlands" />
      </div>

      <div class="links-section">
        <div class="links-label">Brands &amp; Friends</div>
        <LinkItem href="https://dubeskills.eu/" icon="DS" title="Dubé Skills" desc="Developing the future of hockey — professionelle Spielerentwicklung auf höchstem Niveau" />
        <LinkItem href="https://www.create-sports.com" icon="CS" title="Create-Sports" desc="Hockeyshop #1 — Wir leben Eishockey" />
        <LinkItem href="https://www.cherrysgraph.de/" icon="LK" title="Lukas Kirsch" desc="Fotografie & Visual Storytelling — die Bilder hinter Shift2Pro" />
      </div>

      <div class="links-section">
        <div class="links-label">Fotografie</div>
        <LinkItem href="https://unsplash.com/de/@wild_projects" icon="UN" title="Unsplash" desc="Momente, die niemandem gehören — und allen. Frei nutzbar." />
      </div>

      <!-- CONNECTOR LINE -->
      <div class="connector-line">
        <div class="connector-line-inner"></div>
      </div>

      <!-- CONTACT -->
      <div class="contact-row">
        <a href="mailto:rene@wildproject.pro" class="contact-pill">rene@wildproject.pro</a>
      </div>
    </div>

    <Footer />
  </div>
</Layout>

<style>
  /* ── FULLSCREEN BG ───────────────── */
  .page-bg {
    position: fixed; top: 0; left: 0; right: 0; bottom: 0;
    background-image: url('/IMG_6431.JPG');
    background-size: cover;
    background-position: center 38%;
    filter: grayscale(1) brightness(0.96) contrast(1.06);
    z-index: 0;
    animation: bgZoom 14s ease-out forwards;
    transform-origin: center 40%;
    transition: filter 0.25s ease-out;
    will-change: filter, transform;
  }
  @keyframes bgZoom {
    0%   { transform: scale(1.10); }
    100% { transform: scale(1.00); }
  }
  /* cinematic vignette */
  .page-bg::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at center 38%, transparent 0%, transparent 45%, rgba(0,0,0,0.35) 100%);
    pointer-events: none;
  }
  /* bottom fade into content */
  .page-bg::after {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; bottom: 0;
    background: linear-gradient(to bottom,
      rgba(5,5,5,0.05) 0%,
      rgba(5,5,5,0.15) 30%,
      rgba(5,5,5,0.55) 58%,
      rgba(5,5,5,0.88) 78%,
      rgba(5,5,5,0.97) 100%);
    pointer-events: none;
  }

  .page-content {
    position: relative; z-index: 1;
    display: flex; flex-direction: column;
  }

  /* ── LOWER SECTION ───────────────── */
  .lower {
    padding: 0 3rem 60px;
    max-width: 560px;
    margin: 0 auto;
    width: 100%;
  }

  /* ── CTA ROW ─────────────────────── */
  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    padding: 28px 0 4px;
    opacity: 0;
    transform: translateY(8px);
    animation: ctaIn 0.6s ease 2.4s forwards;
  }
  @keyframes ctaIn { to { opacity: 1; transform: none; } }
  .cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 24px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 0;
    transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.25s ease, color 0.25s ease, border-color 0.25s ease;
    will-change: transform;
  }
  .cta-arrow {
    display: inline-block;
    transition: transform 0.25s ease;
  }
  .cta:hover .cta-arrow { transform: translateX(3px); }
  .cta-primary {
    background: var(--orange);
    color: #fff;
    box-shadow: 0 6px 24px rgba(252,80,0,0.25);
  }
  .cta-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(252,80,0,0.35);
  }
  .cta-ghost {
    background: transparent;
    color: rgba(255,255,255,0.85);
    border: 1px solid rgba(255,255,255,0.18);
  }
  .cta-ghost:hover {
    color: var(--orange);
    border-color: rgba(252,80,0,0.4);
    transform: translateY(-2px);
  }
  :global(body.light) .cta-ghost {
    color: rgba(0,0,0,0.7);
    border-color: rgba(0,0,0,0.15);
  }
  :global(body.light) .cta-ghost:hover {
    color: var(--orange);
    border-color: rgba(252,80,0,0.4);
  }

  @keyframes fadeIn { to { opacity: 1; } }


  /* ── ABOUT TOGGLE ────────────────── */
  .about-toggle {
    display: flex; align-items: center; justify-content: space-between;
    padding: 18px 0;
    border-top: 1px solid rgba(255,255,255,0.08);
    cursor: pointer;
    user-select: none;
    transition: opacity 0.2s;
  }
  .about-toggle:hover { opacity: 1; }
  .about-toggle:hover .about-toggle-label { color: var(--white); }
  .about-toggle:hover .about-toggle-icon { border-color: var(--orange); color: var(--orange); transform: scale(1.1); }
  .about-toggle-label {
    font-size: 11px; font-weight: 500;
    letter-spacing: 3px; text-transform: uppercase;
    color: var(--orange);
    transition: color 0.3s;
  }
  .about-toggle-icon {
    width: 28px; height: 28px;
    display: flex; align-items: center; justify-content: center;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 50%;
    color: var(--grey-mid);
    font-size: 16px; font-weight: 300;
    transition: all 0.3s;
  }
  .about-toggle.open .about-toggle-icon {
    transform: rotate(45deg);
    border-color: var(--orange);
    color: var(--orange);
  }
  .about-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.5s ease, opacity 0.4s ease;
    opacity: 0;
  }
  .about-body.open {
    max-height: 600px;
    opacity: 1;
  }
  .about-body-inner {
    padding: 8px 0 28px;
  }
  .about-text {
    font-size: 14px;
    color: var(--grey-mid);
    line-height: 1.8;
    font-weight: 300;
  }
  .about-text + .about-text {
    margin-top: 12px;
  }
  .about-stats {
    display: flex; gap: 24px; margin-top: 20px;
  }
  .stat {
    padding: 14px 18px;
    background: rgba(255,255,255,0.04);
    backdrop-filter: blur(4px);
    transition: all 0.3s;
  }
  .stat:hover {
    background: rgba(252,80,0,0.08);
    transform: translateY(-2px);
  }
  .stat-link { text-decoration: none; color: inherit; }
  .stat-number {
    font-size: 20px; font-weight: 700;
    color: var(--orange);
    margin-bottom: 2px;
  }
  .stat-label {
    font-size: 9px; color: var(--grey-mid);
    letter-spacing: 1px; text-transform: uppercase;
  }

  /* ── LINKTREE ────────────────────── */
  .links-section {
    margin-top: 12px;
    border-top: 1px solid rgba(255,255,255,0.08);
    padding-top: 24px;
  }
  .links-label {
    font-size: 11px; font-weight: 500;
    letter-spacing: 3px; text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 16px;
  }

  /* ── CONNECTOR LINE ─────────────── */
  .connector-line {
    display: flex;
    justify-content: center;
    padding: 8px 0;
  }
  .connector-line-inner {
    width: 1px;
    height: 0;
    background: linear-gradient(to bottom, var(--orange), rgba(252,80,0,0.05));
    transition: height 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .connector-line.visible .connector-line-inner {
    height: 36px;
  }

  /* ── CONTACT ROW ─────────────────── */
  .contact-row {
    margin-top: 0;
    padding-top: 8px;
    display: flex; align-items: center; justify-content: center;
    gap: 20px;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.5s ease 0.4s, transform 0.5s ease 0.4s;
  }
  .contact-row.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .contact-pill {
    font-size: 11px; font-weight: 400;
    letter-spacing: 1px;
    color: var(--grey-mid);
    padding: 10px 18px;
    border: 1px solid rgba(255,255,255,0.06);
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
  }
  .contact-pill::before {
    content: '';
    position: absolute;
    top: 0; left: -100%;
    width: 100%; height: 1px;
    background: linear-gradient(90deg, transparent, var(--orange), transparent);
    transition: left 0.6s ease;
  }
  .contact-pill::after {
    content: '';
    position: absolute;
    bottom: 0; right: -100%;
    width: 100%; height: 1px;
    background: linear-gradient(90deg, transparent, var(--orange), transparent);
    transition: right 0.6s ease;
  }
  .contact-pill:hover::before { left: 0; }
  .contact-pill:hover::after { right: 0; }
  .contact-pill:hover {
    color: var(--white);
    border-color: rgba(252,80,0,0.3);
    background: rgba(252,80,0,0.06);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(252,80,0,0.08);
  }

  /* ── LIGHT MODE ───────────────────── */
  :global(body.light) .page-bg {
    filter: grayscale(0.25) brightness(0.98) contrast(1.04);
  }
  :global(body.light) .page-bg::before {
    background: radial-gradient(ellipse at center 38%, transparent 0%, transparent 50%, rgba(0,0,0,0.18) 100%);
  }
  :global(body.light) .page-bg::after {
    background: linear-gradient(to bottom,
      rgba(245,245,243,0.05) 0%,
      rgba(245,245,243,0.18) 30%,
      rgba(245,245,243,0.6) 58%,
      rgba(245,245,243,0.9) 78%,
      rgba(245,245,243,0.99) 100%);
  }
  :global(body.light) .about-toggle {
    border-top-color: rgba(0,0,0,0.08);
  }
  :global(body.light) .about-toggle-label { color: var(--orange); }
  :global(body.light) .about-toggle:hover .about-toggle-label { color: #1a1a1a; }
  :global(body.light) .about-toggle-icon {
    border-color: rgba(0,0,0,0.12);
    color: rgba(0,0,0,0.35);
  }
  :global(body.light) .about-text { color: rgba(0,0,0,0.55); }
  :global(body.light) .stat {
    background: rgba(0,0,0,0.03);
    border: 1px solid rgba(0,0,0,0.05);
  }
  :global(body.light) .stat:hover {
    background: rgba(252,80,0,0.05);
    border-color: rgba(252,80,0,0.12);
  }
  :global(body.light) .stat-number { color: var(--orange); }
  :global(body.light) .stat-label { color: rgba(0,0,0,0.4); }
  :global(body.light) .links-section {
    border-top-color: rgba(0,0,0,0.06);
  }
  :global(body.light) .links-label { color: var(--orange); }
  :global(body.light) .connector-line-inner {
    background: linear-gradient(to bottom, var(--orange), rgba(252,80,0,0.05));
  }
  :global(body.light) .contact-pill {
    color: rgba(0,0,0,0.45);
    border-color: rgba(0,0,0,0.08);
  }
  :global(body.light) .contact-pill:hover {
    color: #1a1a1a;
    border-color: rgba(252,80,0,0.25);
    background: rgba(252,80,0,0.04);
  }
  :global(body.light) .contact-pill::before,
  :global(body.light) .contact-pill::after {
    background: linear-gradient(90deg, transparent, var(--orange), transparent);
  }

  /* ── RESPONSIVE ──────────────────── */
  @media (max-width: 700px) {
    .page-bg { background-position: center 30%; }
    .lower { padding: 0 1.5rem 40px; }
    .links-section { margin-top: 2px; padding-top: 6px; }
    .links-label { margin-bottom: 4px; font-size: 9px; }
    .about-toggle { padding: 6px 0; }
    .about-toggle-label { font-size: 9px; }
    .about-stats { flex-wrap: wrap; }
    .connector-line { padding: 12px 0; }
    .connector-line.visible .connector-line-inner { height: 32px; }
    .contact-row { flex-direction: column; gap: 6px; margin-top: 0; padding-top: 12px; }
    .contact-pill { width: 100%; text-align: center; padding: 6px 12px; font-size: 9px; }
  }
</style>

<script>
  // About toggle
  document.getElementById('aboutToggle')?.addEventListener('click', function() {
    this.classList.toggle('open');
    document.getElementById('aboutBody')?.classList.toggle('open');
  });

  // Connector line + contact row reveal on scroll
  const connector = document.querySelector('.connector-line');
  const contactRow = document.querySelector('.contact-row');
  if (connector) {
    const obs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          connector.classList.add('visible');
          contactRow?.classList.add('visible');
          obs.unobserve(e.target);
        }
      });
    }, { threshold: 0.5 });
    obs.observe(connector);
  }

  // Scroll-based background brightness
  (function() {
    const bg = document.querySelector('.page-bg') as HTMLElement;
    if (!bg) return;
    const darkMax = 0.96, darkMin = 0.42;
    const lightMax = 0.98, lightMin = 0.78;
    let ticking = false;

    // ease-out cubic for smoother feel
    const ease = (t: number) => 1 - Math.pow(1 - t, 3);

    function updateBrightness() {
      const scrollY = window.scrollY;
      const trigger = window.innerHeight * 0.85;
      const progress = ease(Math.min(scrollY / trigger, 1));
      const isLight = document.body.classList.contains('light');
      if (isLight) {
        const b = lightMax - (lightMax - lightMin) * progress;
        bg.style.filter = 'grayscale(0.25) brightness(' + b.toFixed(3) + ') contrast(1.04)';
      } else {
        const b = darkMax - (darkMax - darkMin) * progress;
        bg.style.filter = 'grayscale(1) brightness(' + b.toFixed(3) + ') contrast(1.06)';
      }
      ticking = false;
    }

    window.addEventListener('scroll', function() {
      if (!ticking) {
        requestAnimationFrame(updateBrightness);
        ticking = true;
      }
    });
  })();

  // Date / Time / Weather → moved to Nav.astro
</script>
