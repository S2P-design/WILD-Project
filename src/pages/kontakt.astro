---
import LegalLayout from '../layouts/LegalLayout.astro';
---

<LegalLayout
  title="Kontakt — Wild Project"
  description="Kontaktiere Wild Project direkt. Kein Bot, kein Callcenter."
  pageTitle="Kontakt"
  intro="Kurz, direkt, fertig."
>
  <h2>Nachricht senden</h2>
  <p>Kein Account, kein Login — einfach ausfüllen. Dein Mail-Programm öffnet sich mit der fertigen Nachricht.</p>

  <form class="contact-form" id="contactForm" onsubmit="return sendMail()">
    <div class="form-field">
      <label for="name">Name</label>
      <input type="text" id="name" required autocomplete="name" placeholder="Dein Name">
    </div>
    <div class="form-field">
      <label for="email">E-Mail</label>
      <input type="email" id="email" required autocomplete="email" placeholder="Deine E-Mail-Adresse">
    </div>
    <div class="form-field">
      <label for="message">Nachricht</label>
      <textarea id="message" rows="5" required placeholder="Was liegt an?"></textarea>
    </div>
    <button type="submit" class="form-btn">Mail öffnen</button>
  </form>

  <h2>Oder direkt</h2>
  <p>E-Mail: <a href="mailto:rene@wildproject.pro">rene@wildproject.pro</a></p>

  <script is:inline>
    function sendMail() {
      var name = document.getElementById('name').value.trim();
      var email = document.getElementById('email').value.trim();
      var msg = document.getElementById('message').value.trim();
      var subject = encodeURIComponent('Kontaktanfrage von ' + name);
      var body = encodeURIComponent('Name: ' + name + '\nE-Mail: ' + email + '\n\n' + msg);
      window.location.href = 'mailto:rene@wildproject.pro?subject=' + subject + '&body=' + body;
      return false;
    }
  </script>

</LegalLayout>

<style>
  .contact-form {
    margin: 24px 0 32px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .form-field label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--grey-dark);
  }

  .form-field input,
  .form-field textarea {
    font-family: 'Poppins', sans-serif;
    font-size: 14px;
    font-weight: 300;
    color: var(--silver);
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 4px;
    padding: 12px 16px;
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
  }

  .form-field input::placeholder,
  .form-field textarea::placeholder {
    color: var(--grey-dark);
    font-weight: 300;
  }

  .form-field input:focus,
  .form-field textarea:focus {
    border-color: var(--orange);
  }

  .form-field textarea {
    resize: vertical;
    min-height: 120px;
  }

  .form-btn {
    font-family: 'Poppins', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--black);
    background: var(--orange);
    border: none;
    border-radius: 4px;
    padding: 14px 32px;
    cursor: pointer;
    transition: opacity 0.2s;
    align-self: flex-start;
  }

  .form-btn:hover {
    opacity: 0.85;
  }
</style>
