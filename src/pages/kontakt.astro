---
import LegalLayout from '../layouts/LegalLayout.astro';
---

<LegalLayout
  title="Kontakt — Wild Project"
  description="Kontaktiere Wild Project direkt. Kein Bot, kein Callcenter."
  pageTitle="Kontakt"
  intro="Kurz, direkt, fertig."
>
  <h2><span class="t-de">Nachricht senden</span><span class="t-en">Send a message</span></h2>
  <p><span class="t-de">Kein Account, kein Login — einfach ausfüllen. Dein Mail-Programm öffnet sich mit der fertigen Nachricht.</span><span class="t-en">No account, no login — just fill in the form. Your mail app opens with the message ready to send.</span></p>

  <form class="contact-form" id="contactForm" onsubmit="return sendMail()">
    <div class="form-field">
      <label for="name"><span class="t-de">Name</span><span class="t-en">Name</span></label>
      <input type="text" id="name" required autocomplete="name">
    </div>
    <div class="form-field">
      <label for="email"><span class="t-de">E-Mail</span><span class="t-en">Email</span></label>
      <input type="email" id="email" required autocomplete="email">
    </div>
    <div class="form-field">
      <label for="message"><span class="t-de">Nachricht</span><span class="t-en">Message</span></label>
      <textarea id="message" rows="5" required></textarea>
    </div>
    <button type="submit" class="form-btn"><span class="t-de">Mail öffnen</span><span class="t-en">Open mail</span></button>
  </form>

  <h2><span class="t-de">Oder direkt</span><span class="t-en">Or directly</span></h2>
  <p>E-Mail: <a href="mailto:rene@wildproject.pro">rene@wildproject.pro</a></p>

  <script is:inline>
    function sendMail() {
      var name = document.getElementById('name').value.trim();
      var email = document.getElementById('email').value.trim();
      var msg = document.getElementById('message').value.trim();
      var lang = document.documentElement.getAttribute('data-lang');
      var subject, body;
      if (lang === 'en') {
        subject = encodeURIComponent('Contact request from ' + name);
        body = encodeURIComponent('Name: ' + name + '\nEmail: ' + email + '\n\n' + msg);
      } else {
        subject = encodeURIComponent('Kontaktanfrage von ' + name);
        body = encodeURIComponent('Name: ' + name + '\nE-Mail: ' + email + '\n\n' + msg);
      }
      window.location.href = 'mailto:rene@wildproject.pro?subject=' + subject + '&body=' + body;
      return false;
    }
    // Set placeholders based on language
    (function() {
      var lang = document.documentElement.getAttribute('data-lang') || 'de';
      var ph = lang === 'en'
        ? { name: 'Your name', email: 'Your email address', message: 'What\'s on your mind?' }
        : { name: 'Dein Name', email: 'Deine E-Mail-Adresse', message: 'Was liegt an?' };
      document.getElementById('name').placeholder = ph.name;
      document.getElementById('email').placeholder = ph.email;
      document.getElementById('message').placeholder = ph.message;
    })();
  </script>

</LegalLayout>

<style>
  .contact-form {
    margin: 24px 0 32px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .form-field label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--grey-dark);
  }

  .form-field input,
  .form-field textarea {
    font-family: 'Poppins', sans-serif;
    font-size: 14px;
    font-weight: 300;
    color: var(--silver);
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 4px;
    padding: 12px 16px;
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
  }

  .form-field input::placeholder,
  .form-field textarea::placeholder {
    color: var(--grey-dark);
    font-weight: 300;
  }

  .form-field input:focus,
  .form-field textarea:focus {
    border-color: var(--orange);
  }

  .form-field textarea {
    resize: vertical;
    min-height: 120px;
  }

  .form-btn {
    font-family: 'Poppins', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--black);
    background: var(--orange);
    border: none;
    border-radius: 4px;
    padding: 14px 32px;
    cursor: pointer;
    transition: opacity 0.2s;
    align-self: flex-start;
  }

  .form-btn:hover {
    opacity: 0.85;
  }
</style>
