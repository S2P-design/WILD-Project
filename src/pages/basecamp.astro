---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Basecamp · Wild Project</title>
  <meta name="description" content="Brand Assets vom Wild Project. Logos, Farben, Schriften — frei verwendbar für Sponsoren, Partner und Presse.">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/favicon-180.png">
</head>
<body>

<nav>
  <a href="/" class="nav-brand"><img src="/wp-logo.png" alt="Wild Project" class="nav-logo"></a>
  <a href="/" class="nav-back">&larr; Zur&uuml;ck</a>
</nav>

<header class="hero">
  <div class="hero-eyebrow">
    <span class="dot"></span>
    BASECAMP &middot; N&deg;01 &middot; WP/26
  </div>
  <h1>Basecamp<span>.</span></h1>
  <p class="tagline">Brand Assets. Alles an einem Ort.</p>
  <div class="hero-statement">
    <span class="br">[</span>LOGOS<span class="br">]</span>
    <span class="br">[</span>COLORS<span class="br">]</span>
    <span class="br">[</span>FONTS<span class="br">]</span>
  </div>
</header>

<main class="page">

  <!-- ═══════════════════ 01 BRAND ═══════════════════ -->
  <section class="section">
    <div class="section-head">
      <div class="section-num">01</div>
      <h2>Brand Identity</h2>
      <span class="section-access">&bull; open access</span>
    </div>
    <p class="section-intro">
      Logos, Farben und Schriften. Frei verwendbar f&uuml;r Sponsoren, Partner und Presse
      im Rahmen der Brand Guidelines.
    </p>

    <div class="card-grid">

      <!-- Logo Orange -->
      <div class="dl-card">
        <div class="dl-preview preview-dark">
          <img src="/basecamp/brand/logos/wp-monogram-orange.png" alt="WP Monogram Orange" />
        </div>
        <div class="dl-meta">
          <div class="dl-marks">
            <span>N&deg;01</span>
            <span>WP/26</span>
          </div>
          <h3>WP Monogram &mdash; Orange</h3>
          <p class="dl-desc">Hauptlogo. Flameburst <code>#FC5000</code>. F&uuml;r dunkle Backgrounds & Akzente.</p>
          <div class="dl-tags">
            <span>PNG</span>
            <span>180 KB</span>
            <span>1:1</span>
          </div>
          <a class="dl-btn" href="/basecamp/brand/logos/wp-monogram-orange.png" download>
            Download <span class="arrow">&rarr;</span>
          </a>
        </div>
      </div>

      <!-- Logo Black -->
      <div class="dl-card">
        <div class="dl-preview preview-light">
          <img src="/basecamp/brand/logos/wp-monogram-black.png" alt="WP Monogram Black" />
        </div>
        <div class="dl-meta">
          <div class="dl-marks">
            <span>N&deg;02</span>
            <span>WP/26</span>
          </div>
          <h3>WP Monogram &mdash; Black</h3>
          <p class="dl-desc">Midnight <code>#050505</code>. F&uuml;r helle Backgrounds, Print & formelle Docs.</p>
          <div class="dl-tags">
            <span>PNG</span>
            <span>176 KB</span>
            <span>1:1</span>
          </div>
          <a class="dl-btn" href="/basecamp/brand/logos/wp-monogram-black.png" download>
            Download <span class="arrow">&rarr;</span>
          </a>
        </div>
      </div>

      <!-- Logo White -->
      <div class="dl-card">
        <div class="dl-preview preview-dark">
          <img src="/basecamp/brand/logos/wp-monogram-white.png" alt="WP Monogram White" />
        </div>
        <div class="dl-meta">
          <div class="dl-marks">
            <span>N&deg;03</span>
            <span>WP/26</span>
          </div>
          <h3>WP Monogram &mdash; White</h3>
          <p class="dl-desc">Pure White. F&uuml;r dunkle Backgrounds, Watermarks & Footer.</p>
          <div class="dl-tags">
            <span>PNG</span>
            <span>172 KB</span>
            <span>1:1</span>
          </div>
          <a class="dl-btn" href="/basecamp/brand/logos/wp-monogram-white.png" download>
            Download <span class="arrow">&rarr;</span>
          </a>
        </div>
      </div>

      <!-- Logo Pack (ZIP) -->
      <div class="dl-card dl-card-feat">
        <div class="dl-preview preview-pack">
          <div class="pack-grid">
            <div class="pack-tile tile-orange">
              <img src="/basecamp/brand/logos/wp-monogram-orange.png" alt="" />
            </div>
            <div class="pack-tile tile-light">
              <img src="/basecamp/brand/logos/wp-monogram-black.png" alt="" />
            </div>
            <div class="pack-tile tile-dark">
              <img src="/basecamp/brand/logos/wp-monogram-white.png" alt="" />
            </div>
            <div class="pack-tile tile-zip">
              <span class="zip-mark">.ZIP</span>
              <span class="zip-count">4 FILES</span>
            </div>
          </div>
        </div>
        <div class="dl-meta">
          <div class="dl-marks">
            <span>PACK</span>
            <span>ALL/WP/26</span>
          </div>
          <h3>Logo Pack &mdash; Alle Varianten</h3>
          <p class="dl-desc">Alle Monogramm-Varianten (Orange, Black, White, Signature) in einem ZIP.</p>
          <div class="dl-tags">
            <span>ZIP</span>
            <span>514 KB</span>
            <span>4 Files</span>
          </div>
          <a class="dl-btn" href="/basecamp/brand/logos/wp-logo-pack.zip" download>
            Download <span class="arrow">&rarr;</span>
          </a>
        </div>
      </div>

      <!-- Colors — 4 stripe palette -->
      <div class="dl-card">
        <div class="dl-preview preview-colors">
          <div class="palette-stripes">
            <span class="stripe" style="background:#FC5000;"></span>
            <span class="stripe" style="background:#050505;"></span>
            <span class="stripe" style="background:#888888;"></span>
            <span class="stripe" style="background:#E4E4E4;"></span>
          </div>
          <div class="palette-strip">
            <span class="chip-hex">PALETTE &middot; 4 COLORS</span>
            <span class="chip-mark">WP/26</span>
          </div>
        </div>
        <div class="dl-meta">
          <div class="dl-marks">
            <span>N&deg;04</span>
            <span>WP/26</span>
          </div>
          <h3>Farbpalette</h3>
          <p class="dl-desc">Flameburst Orange, Midnight, Silver Mist. HEX/RGB/CMYK Referenz.</p>
          <div class="dl-tags">
            <span>TXT</span>
            <span>&lt; 2 KB</span>
          </div>
          <a class="dl-btn" href="/basecamp/brand/colors/wild-project-colors.txt" download>
            Download <span class="arrow">&rarr;</span>
          </a>
        </div>
      </div>

      <!-- Brand Guide -->
      <div class="dl-card">
        <div class="dl-preview preview-guide">
          <div class="guide-specimen">
            <span class="spec-aa">Aa</span>
            <span class="spec-grid">
              <span class="spec-bar"></span>
              <span class="spec-bar"></span>
              <span class="spec-bar"></span>
            </span>
            <span class="spec-label">[BRAND GUIDE]</span>
          </div>
        </div>
        <div class="dl-meta">
          <div class="dl-marks">
            <span>N&deg;05</span>
            <span>WP/26</span>
          </div>
          <h3>Brand Guide</h3>
          <p class="dl-desc">Logo, Typografie, Farben, Tone of Voice. Die komplette Bibel.</p>
          <div class="dl-tags">
            <span>HTML</span>
            <span>open</span>
          </div>
          <a class="dl-btn" href="/brand-guide.html" target="_blank">
            &Ouml;ffnen <span class="arrow">&rarr;</span>
          </a>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════ FOOTER NOTE ═══════════════════ -->
  <div class="usage-note">
    <div class="note-eyebrow">
      <span class="dot"></span>
      [NUTZUNGSBEDINGUNGEN]
    </div>
    <p>
      Brand Assets d&uuml;rfen f&uuml;r Partner-, Sponsoring- und Pressezwecke verwendet werden.
      Keine Ver&auml;nderung von Logo, Farben oder Proportionen. Bei kommerzieller oder
      Drittvermarktung vorher kurze Mail an
      <a href="mailto:rene@wildproject.pro">rene@wildproject.pro</a>.
    </p>
  </div>

  <!-- ═══════════════════ MAP MARKER ═══════════════════ -->
  <div class="hq-marker" aria-hidden="true">
    <div class="pin">
      <div class="pin-dot"></div>
      <div class="pin-ring"></div>
    </div>
    <div class="pin-label">
      <div class="pin-city">ROSENHEIM</div>
      <div class="pin-coords">47.8504° N &middot; 12.1321° E</div>
      <div class="pin-tag">[WILD PROJECT HQ]</div>
    </div>
  </div>

</main>

<footer class="footer">
  <p>&copy; 2026 Wild Project &mdash; Ren&eacute; Wild</p>
  <p style="margin-top: 8px;">
    <a href="/">Startseite</a> &middot;
    <a href="/impressum">Impressum</a> &middot;
    <a href="/datenschutz">Datenschutz</a>
  </p>
</footer>

</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<style>
  /* ── TECHNICAL BACKGROUND ─────────── */
  /* Pure black — uniform dot grid */
  body {
    background-color: #000000;
    background-image:
      radial-gradient(circle at 1px 1px, rgba(255,255,255,0.06) 1px, transparent 1.5px);
    background-size: 24px 24px;
    background-attachment: fixed;
  }

  /* ── HQ MARKER (on map) ─────────────── */
  .hq-marker {
    position: fixed;
    right: 32px;
    bottom: 32px;
    display: flex;
    align-items: flex-start;
    gap: 12px;
    z-index: 40;
    pointer-events: none;
    padding: 12px 14px;
    background: rgba(10,10,10,0.72);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border: 1px solid rgba(255,255,255,0.08);
    border-left: 2px solid var(--orange);
  }
  .pin {
    position: relative;
    width: 22px;
    height: 22px;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .pin-dot {
    position: absolute;
    left: 50%; top: 50%;
    width: 10px; height: 10px;
    border-radius: 50%;
    background: var(--orange);
    box-shadow: 0 0 12px rgba(252,80,0,0.9), 0 0 24px rgba(252,80,0,0.5);
    transform: translate(-50%, -50%);
    z-index: 2;
  }
  .pin-ring {
    position: absolute;
    left: 50%; top: 50%;
    width: 10px; height: 10px;
    border-radius: 50%;
    border: 1.5px solid var(--orange);
    transform: translate(-50%, -50%);
    animation: pinPulse 2.2s ease-out infinite;
  }
  @keyframes pinPulse {
    0%   { width: 10px; height: 10px; opacity: 0.9; }
    100% { width: 46px; height: 46px; opacity: 0; }
  }
  .pin-label {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    line-height: 1.35;
  }
  .pin-city {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
    color: var(--orange);
    text-shadow: 0 0 10px rgba(252,80,0,0.35);
  }
  .pin-coords {
    font-size: 10px;
    letter-spacing: 1.2px;
    color: rgba(255,255,255,0.72);
    margin-top: 3px;
    font-variant-numeric: tabular-nums;
  }
  .pin-tag {
    font-size: 9px;
    letter-spacing: 1.5px;
    color: rgba(255,255,255,0.45);
    margin-top: 2px;
  }
  @media (max-width: 700px) {
    /* Inline instead of fixed HUD — no overlap with footer */
    .hq-marker {
      position: static;
      transform: none;
      display: inline-flex;
      margin: 24px 0 8px;
      gap: 10px;
      padding: 10px 12px;
    }
    .pin { width: 18px; height: 18px; }
    .pin-city { font-size: 10px; }
    .pin-coords { font-size: 9px; }
    .pin-tag { font-size: 8px; }
  }

  /* Nav background to match warmer dark */
  nav { background: rgba(20,18,16,0.92) !important; }

  /* ── NAV ─────────────────────────── */
  nav {
    display: flex; align-items: center; justify-content: space-between;
    padding: 24px 3rem;
    position: sticky; top: 0;
    background: rgba(5,5,5,0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    z-index: 50;
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }
  .nav-brand { display: flex; align-items: center; }
  .nav-logo { height: 36px; width: auto; }
  .nav-back {
    font-size: 11px; font-weight: 400;
    letter-spacing: 2px; text-transform: uppercase;
    color: var(--grey-mid);
    transition: color 0.2s;
    text-decoration: none;
  }
  .nav-back:hover { color: var(--orange); }

  /* ── HERO ────────────────────────── */
  .hero {
    max-width: 1100px;
    margin: 0 auto;
    padding: 72px 3rem 40px;
    position: relative;
  }
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    padding: 6px 12px;
    border: 1px solid rgba(255,255,255,0.08);
    background: rgba(255,255,255,0.02);
    margin-bottom: 28px;
  }
  .hero-eyebrow .dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--orange);
    animation: heroPulse 2.4s ease-in-out infinite;
  }
  @keyframes heroPulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(252,80,0,0.55); transform: scale(1); }
    50%      { box-shadow: 0 0 0 6px rgba(252,80,0,0); transform: scale(1.15); }
  }
  .hero h1 {
    font-size: clamp(3rem, 9vw, 6rem);
    font-weight: 700;
    letter-spacing: -3px;
    line-height: 0.95;
    color: var(--white);
    margin: 0 0 14px;
  }
  .hero h1 span { color: var(--orange); }
  .hero .tagline {
    font-size: clamp(1rem, 1.6vw, 1.15rem);
    color: var(--grey-mid);
    font-style: italic;
    margin: 0 0 20px;
    max-width: 620px;
  }
  .hero-statement {
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: clamp(10px, 1vw, 12px);
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.85);
    margin-top: 10px;
  }
  .hero-statement .br {
    color: var(--orange);
    font-weight: 400;
    margin: 0 2px;
  }

  /* ── PAGE WRAP ───────────────────── */
  .page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 20px 3rem 80px;
  }

  /* ── SECTION ─────────────────────── */
  .section {
    margin-bottom: 72px;
    position: relative;
  }
  .section-head {
    display: flex;
    align-items: baseline;
    gap: 14px;
    margin-bottom: 10px;
    padding-bottom: 14px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .section-num {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1px;
    color: var(--orange);
    padding: 3px 8px;
    border: 1px solid var(--orange);
    background: rgba(252,80,0,0.06);
  }
  .section-head h2 {
    font-size: clamp(1.4rem, 2.8vw, 1.8rem);
    font-weight: 700;
    letter-spacing: -0.5px;
    color: var(--white);
    margin: 0;
  }
  .section-access {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 9px;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: var(--grey-dark);
    margin-left: auto;
  }
  .section-access.gated-label { color: var(--orange); }
  .section-intro {
    font-size: 14px;
    color: var(--grey-mid);
    max-width: 640px;
    margin: 0 0 28px;
    line-height: 1.6;
  }
  .section-intro a { color: var(--orange); }

  /* ── CARD GRID ───────────────────── */
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
  }

  .dl-card {
    position: relative;
    background: #0d0c0b;
    border: 1px solid rgba(255,255,255,0.08);
    overflow: hidden;
    transition: transform 0.25s ease, border-color 0.25s ease;
  }
  .dl-card::before,
  .dl-card::after {
    content: '';
    position: absolute;
    left: 0; right: 0;
    height: 1px;
    background: var(--orange);
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .dl-card::before { top: 0; }
  .dl-card::after  { bottom: 0; }
  .dl-card:hover {
    transform: translateY(-2px);
    border-color: rgba(252,80,0,0.25);
  }
  .dl-card:hover::before,
  .dl-card:hover::after { opacity: 0.6; }

  .dl-card-feat {
    border-color: rgba(252,80,0,0.25);
  }
  .dl-card-feat::before,
  .dl-card-feat::after { opacity: 0.4; }

  /* Preview areas */
  .dl-preview {
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .dl-preview img {
    max-width: 52%;
    max-height: 72%;
    object-fit: contain;
  }
  .preview-dark {
    background:
      linear-gradient(135deg, rgba(252,80,0,0.08), rgba(5,5,5,0.6)),
      #0a0a0a;
  }
  .preview-light {
    background: #F7F7F5;
  }
  /* Colors Preview — 4 stripe palette */
  .preview-colors {
    display: flex !important;
    flex-direction: column;
    align-items: stretch !important;
    justify-content: stretch !important;
    padding: 0;
    background: #0a0a0a;
  }
  .palette-stripes {
    flex: 1 1 auto;
    display: flex;
    min-height: 0;
  }
  .stripe {
    flex: 1 1 0;
    height: 100%;
    position: relative;
    border-right: 1px solid rgba(255,255,255,0.08);
  }
  .stripe:last-child { border-right: none; }
  .stripe:first-child::after {
    content: '';
    position: absolute;
    top: 14px;
    left: 14px;
    width: 20px;
    height: 1.5px;
    background: rgba(0,0,0,0.4);
  }
  .palette-strip {
    background: #050505;
    padding: 10px 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid rgba(255,255,255,0.06);
  }
  .chip-hex {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 9.5px;
    font-weight: 700;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--white);
  }
  .chip-mark {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 8px;
    font-weight: 600;
    letter-spacing: 1.4px;
    color: rgba(255,255,255,0.4);
  }

  /* Logo Pack — 2x2 grid with all variants + zip mark */
  .preview-pack {
    background: #0a0a0a;
    padding: 0;
  }
  .pack-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    width: 100%;
    height: 100%;
    gap: 1px;
    background: rgba(255,255,255,0.06);
  }
  .pack-tile {
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
  }
  .pack-tile img {
    max-width: 60%;
    max-height: 72%;
    object-fit: contain;
  }
  .tile-orange { background: linear-gradient(135deg, rgba(252,80,0,0.14), rgba(5,5,5,0.6)), #0a0a0a; }
  .tile-light  { background: #F7F7F5; }
  .tile-dark   { background: #050505; }
  .tile-zip {
    background:
      repeating-linear-gradient(45deg,
        rgba(252,80,0,0.08) 0 6px,
        transparent 6px 12px),
      #0a0a0a;
    flex-direction: column;
    gap: 2px;
  }
  .zip-mark {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 1px;
    color: var(--orange);
  }
  .zip-count {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 7.5px;
    font-weight: 600;
    letter-spacing: 1.4px;
    color: rgba(255,255,255,0.55);
  }

  /* Brand Guide — typographic specimen */
  .preview-guide {
    background:
      linear-gradient(135deg, rgba(252,80,0,0.06), rgba(5,5,5,0.6)),
      #0a0a0a;
    position: relative;
  }
  .guide-specimen {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    position: relative;
  }
  .spec-aa {
    font-family: 'Poppins', system-ui, sans-serif;
    font-size: 68px;
    font-weight: 700;
    line-height: 0.9;
    color: var(--white);
    letter-spacing: -3px;
    position: relative;
  }
  .spec-aa::after {
    content: '';
    position: absolute;
    right: -10px;
    top: 4px;
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--orange);
  }
  .spec-grid {
    display: flex;
    gap: 4px;
  }
  .spec-bar {
    display: block;
    width: 18px;
    height: 2px;
